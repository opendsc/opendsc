@page "/configurations/{Name}"
@attribute [Authorize]
@using OpenDsc.Server.Services
@using NuGet.Versioning
@using OpenDsc.Contracts.Configurations
@using ConfigurationDetails = OpenDsc.Contracts.Configurations.ConfigurationDetails
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject IConfigurationService ConfigurationService

<PageTitle>@Name - Configuration</PageTitle>

@if (configuration != null)
{
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-4"
               OnClick="@(() => Navigation.NavigateTo("/configurations"))">
        Back to Configurations
    </MudButton>

    <MudText Typo="Typo.h4" Class="mb-4">@configuration.Name</MudText>

    <MudTabs Elevation="4" Rounded="true" Color="Color.Primary">
        <MudTabPanel Text="Versions" Icon="@Icons.Material.Filled.History">
            <MudCard Class="mt-4">
                <MudCardHeader>
                    <CardHeaderActions>
                        <MudMenu Label="New Version" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                 StartIcon="@Icons.Material.Filled.Add" EndIcon="@Icons.Material.Filled.ArrowDropDown">
                            <MudMenuItem OnClick="OpenCreateVersionDialog" Icon="@Icons.Material.Filled.Upload">
                                Upload Files
                            </MudMenuItem>
                            <MudMenuItem OnClick="OpenCreateVersionFromExistingDialog"
                                         Icon="@Icons.Material.Filled.ContentCopy">
                                Create from Existing Version
                            </MudMenuItem>
                        </MudMenu>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (versions.Any())
                    {
                        <MudExpansionPanels MultiExpansion="true" Class="mt-2">
                            @foreach (var major in availableConfigMajors)
                            {
                                var majorVersions = versions
                                    .Where(v => SemanticVersion.TryParse(v.Version, out _) && SemanticVersion.Parse(v.Version).Major ==
                        major)
                                    .OrderByDescending(v => SemanticVersion.TryParse(v.Version, out var sv) ? sv : new
                        SemanticVersion(0, 0, 0))
                                    .ToList();
                                var draftCount = majorVersions.Count(v => v.Status == ConfigurationVersionStatus.Draft);
                                var publishedVersions = majorVersions.Where(v => v.Status ==
                        ConfigurationVersionStatus.Published).ToList();
                                var publishedStable = publishedVersions.FirstOrDefault(v => SemanticVersion.TryParse(v.Version, out
                        var sv) && !sv.IsPrerelease);
                                var publishedPrerelease = publishedVersions.FirstOrDefault(v => SemanticVersion.TryParse(v.Version,
                        out var sv) && sv.IsPrerelease);

                                <MudExpansionPanel Expanded="false">
                                    <TitleContent>
                                        <div class="d-flex align-center gap-2">
                                            <MudText>Version @(major)</MudText>
                                            @if (publishedStable != null)
                                            {
                                                <MudTooltip Text="Latest stable published version">
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Stable:
                                                        @publishedStable.Version</MudChip>
                                                    </MudTooltip>
                                                }
                                                @if (publishedPrerelease != null)
                                                {
                                                    <MudTooltip Text="Latest prerelease published version">
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Prerelease:
                                                            @publishedPrerelease.Version</MudChip>
                                                        </MudTooltip>
                                                    }
                                                    @if (publishedStable == null && publishedPrerelease == null && majorVersions.Any())
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">No Published</MudChip>
                                                    }
                                                    @if (majorVersions.Any())
                                                    {
                                                        <MudChip T="string" Size="Size.Small">@majorVersions.Count @(majorVersions.Count == 1 ?
                                                                                                                                                   "version" : "versions")</MudChip>
                                                        }
                                                        @if (draftCount > 0)
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@draftCount @(draftCount == 1 ?
                                                                                                                                                            "draft" : "drafts")</MudChip>
                                                            }
                                                        </div>
                                                    </TitleContent>
                                                    <ChildContent>
                                                        @foreach (var version in majorVersions)
                                                        {
                                                            <MudExpansionPanel Expanded="false" Class="mb-3">
                                                                <TitleContent>
                                                                    <div class="d-flex align-center gap-2">
                                                                        <MudText Typo="Typo.h6">@version.Version</MudText>
                                                                        @if (version.Status == ConfigurationVersionStatus.Draft)
                                                                        {
                                                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Draft</MudChip>
                                                                        }
                                                                        else
                                                                        {
                                                                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Published</MudChip>
                                                                        }
                                                                        @if (SemanticVersion.TryParse(version.Version, out var vSv) && vSv.IsPrerelease)
                                                                        {
                                                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Prerelease</MudChip>
                                                                        }
                                                                        <MudChip T="string" Size="Size.Small">@version.Files.Count files</MudChip>
                                                                    </div>
                                                                    <MudText Typo="Typo.caption">Created: @version.CreatedAt.LocalDateTime.ToString("g")
                                                                    </MudText>
                                                                </TitleContent>
                                                                <ChildContent>
                                                                    <div class="d-flex justify-end mb-2">
                                                                        @if (version.Status == ConfigurationVersionStatus.Draft)
                                                                        {
                                                                            <MudTooltip Text="Change Entry Point">
                                                                                <MudIconButton Icon="@Icons.Material.Filled.Flag" Size="Size.Small"
                                                                                               Color="Color.Secondary"
                                                                                               OnClick="@(() => OpenChangeEntryPointDialog(version))" />
                                                                            </MudTooltip>
                                                                            <MudMenu AnchorOrigin="Origin.BottomLeft" Dense="true">
                                                                                <ActivatorContent>
                                                                                    <MudTooltip Text="Add Files to Draft">
                                                                                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                                                                                       Color="Color.Primary" />
                                                                                    </MudTooltip>
                                                                                </ActivatorContent>
                                                                                <ChildContent>
                                                                                    <MudMenuItem OnClick="@(() => OpenAddFilesDialog(version))"
                                                                                                 Icon="@Icons.Material.Filled.Upload">
                                                                                        Upload Files
                                                                                    </MudMenuItem>
                                                                                    <MudMenuItem OnClick="@(() => OpenCreateFileDialog(version))"
                                                                                                 Icon="@Icons.Material.Filled.NoteAdd">
                                                                                        Create File
                                                                                    </MudMenuItem>
                                                                                </ChildContent>
                                                                            </MudMenu>
                                                                            <MudTooltip Text="Publish this draft version to make it immutable">
                                                                                <MudIconButton Icon="@Icons.Material.Filled.Publish" Size="Size.Small"
                                                                                               Color="Color.Success" OnClick="@(() => PublishVersion(version))" />
                                                                            </MudTooltip>
                                                                        }
                                                                        <MudTooltip Text="Delete Version">
                                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                                           Color="Color.Error" OnClick="@(() => DeleteVersion(version))" />
                                                                        </MudTooltip>
                                                                    </div>

                                                                    <MudTable Items="@version.Files.OrderBy(f => f.RelativePath)" Dense="true"
                                                                              Hover="true">
                                                                        <HeaderContent>
                                                                            <MudTh>File Path</MudTh>
                                                                            <MudTh>Actions</MudTh>
                                                                        </HeaderContent>
                                                                        <RowTemplate>
                                                                            <MudTd>
                                                                                <div class="d-flex align-center gap-1">
                                                                                    @if (string.Equals(context.RelativePath, version.EntryPoint,
                                                                                                                                                                                                                            StringComparison.OrdinalIgnoreCase))
                                                                                    {
                                                                                        <MudTooltip Text="Entry point">
                                                                                            <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small"
                                                                                                     Color="Color.Secondary" />
                                                                                        </MudTooltip>
                                                                                    }
                                                                                    <span>@context.RelativePath</span>
                                                                                </div>
                                                                            </MudTd>
                                                                            <MudTd>
                                                                                <MudTooltip Text="View File">
                                                                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                                                                   Size="Size.Small"
                                                                                                   OnClick="@(() => OpenFileViewer(version, context, false))" />
                                                                                </MudTooltip>
                                                                                @if (version.Status == ConfigurationVersionStatus.Draft)
                                                                                {
                                                                                    <MudTooltip Text="Edit File">
                                                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                                                       Color="Color.Primary"
                                                                                                       OnClick="@(() => OpenFileViewer(version, context, true))" />
                                                                                    </MudTooltip>
                                                                                }
                                                                                <MudTooltip Text="Download">
                                                                                    <MudIconButton Icon="@Icons.Material.Filled.Download"
                                                                                                   Size="Size.Small"
                                                                                                   OnClick="@(() => DownloadSpecificFile(context, version))" />
                                                                                </MudTooltip>
                                                                                @if (version.Status == ConfigurationVersionStatus.Draft)
                                                                                {
                                                                                    @if (!string.Equals(context.RelativePath, version.EntryPoint,
                                                                                                                                                                                                                        StringComparison.OrdinalIgnoreCase))
                                                                                    {
                                                                                        <MudTooltip Text="Set as Entry Point">
                                                                                            <MudIconButton Icon="@Icons.Material.Filled.Flag" Size="Size.Small"
                                                                                                           Color="Color.Secondary"
                                                                                                           OnClick="@(() => SetEntryPoint(version, context))" />
                                                                                        </MudTooltip>
                                                                                    }
                                                                                    @if (string.Equals(context.RelativePath, version.EntryPoint,
                                                                                                                                                                                                                        StringComparison.OrdinalIgnoreCase))
                                                                                    {
                                                                                        <MudTooltip Text="Change the entry point before deleting this file">
                                                                                            <span>
                                                                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                                                               Size="Size.Small" Color="Color.Error" Disabled="true" />
                                                                                            </span>
                                                                                        </MudTooltip>
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <MudTooltip Text="Delete File">
                                                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                                                           Size="Size.Small" Color="Color.Error"
                                                                                                           OnClick="@(() => DeleteFile(version, context))" />
                                                                                        </MudTooltip>
                                                                                    }
                                                                                }
                                                                            </MudTd>
                                                                        </RowTemplate>
                                                                    </MudTable>
                                                                </ChildContent>
                                                            </MudExpansionPanel>
                                                        }
                                                    </ChildContent>
                                                </MudExpansionPanel>
                                            }
                                        </MudExpansionPanels>
                                    }
                else
                                    {
                                        <MudAlert Severity="Severity.Info">No versions found.</MudAlert>
                                    }
                                </MudCardContent>
                            </MudCard>
                        </MudTabPanel>

                        <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.Info">
                            <MudCard Class="mt-4">
                                <MudCardContent>
                                    <MudSimpleTable Dense="true">
                                        <tbody>
                                            <tr>
                                                <td><strong>Name</strong></td>
                                                <td>@configuration.Name</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Description</strong></td>
                                                <td>@(configuration.Description ?? "-")</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Server Managed Parameters</strong></td>
                                                <td>
                                                    @if (configuration.UseServerManagedParameters)
                                                    {
                                                        <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">
                                                            Enabled</MudChip>
                                                        }
                                    else
                                                        {
                                                            <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Filled">
                                                                Disabled</MudChip>
                                                            }
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td><strong>Created</strong></td>
                                                        <td>@configuration.CreatedAt.LocalDateTime.ToString("g")</td>
                                                    </tr>
                                                    @if (configuration.UpdatedAt.HasValue)
                                                    {
                                                        <tr>
                                                            <td><strong>Updated</strong></td>
                                                            <td>@configuration.UpdatedAt.Value.LocalDateTime.ToString("g")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudCardContent>
                                    </MudCard>
                                </MudTabPanel>

                                <MudTabPanel Text="Settings" Icon="@Icons.Material.Filled.Settings">
                                    <MudCard Class="mt-4">
                                        <MudCardHeader>
                                            <CardHeaderContent>
                                                <MudText Typo="Typo.h6">Retention Policy Override</MudText>
                                                <MudText Typo="Typo.body2">
                                                    Override the global retention policy for this configuration. Leave any field blank to inherit
                                                    the global default.
                                                </MudText>
                                            </CardHeaderContent>
                                        </MudCardHeader>
                                        <MudCardContent>
                                            @if (retentionLoading)
                                            {
                                                <MudProgressLinear Indeterminate="true" />
                                            }
                                            else
                                            {
                                                @if (retentionOverrideActive)
                                                {
                                                    <MudAlert Severity="Severity.Info" Class="mb-4">
                                                        This configuration has custom retention overrides active.
                                                    </MudAlert>
                                                }
                                                else
                                                {
                                                    <MudAlert Severity="Severity.Normal" Class="mb-4">
                                                        Using the <strong>global retention policy</strong>. Set any field below to override.
                                                    </MudAlert>
                                                }

                                                <MudGrid>
                                                    <MudItem xs="12" sm="6">
                                                        <MudTextField T="int?" @bind-Value="retentionKeepVersions" Label="Keep Versions"
                                                                      Variant="Variant.Outlined" InputType="InputType.Number" Placeholder="(global default)"
                                                                      HelperText="Number of most-recent non-draft versions to keep per item." />
                                                    </MudItem>
                                                    <MudItem xs="12" sm="6">
                                                        <MudTextField T="int?" @bind-Value="retentionKeepDays" Label="Keep Days"
                                                                      Variant="Variant.Outlined" InputType="InputType.Number" Placeholder="(global default)"
                                                                      HelperText="Versions newer than this many days are always kept." />
                                                    </MudItem>
                                                    <MudItem xs="12" sm="6">
                                                        <MudSelect T="bool?" @bind-Value="retentionKeepReleaseVersions" Label="Keep Release Versions"
                                                                   Variant="Variant.Outlined" HelperText="Always keep release (non-prerelease) versions.">
                                                            <MudSelectItem T="bool?" Value="@((bool?)null)">Use global default</MudSelectItem>
                                                            <MudSelectItem T="bool?" Value="@((bool?)true)">Yes</MudSelectItem>
                                                            <MudSelectItem T="bool?" Value="@((bool?)false)">No</MudSelectItem>
                                                        </MudSelect>
                                                    </MudItem>
                                                </MudGrid>

                                                @if (retentionSaveError is not null)
                                                {
                                                    <MudAlert Severity="Severity.Error" Class="mt-3">@retentionSaveError</MudAlert>
                                                }

                                                <MudStack Row="true" Spacing="2" Class="mt-4">
                                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveRetentionSettings"
                                                               Disabled="@retentionSaving">
                                                        @if (retentionSaving)
                                                        {
                                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                                        }
                                                        Save
                                                    </MudButton>
                                                    @if (retentionOverrideActive)
                                                    {
                                                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="ResetRetentionSettings"
                                                                   StartIcon="@Icons.Material.Filled.RestartAlt">
                                                            Reset to Global Defaults
                                                        </MudButton>
                                                    }
                                                </MudStack>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                </MudTabPanel>

                                <MudTabPanel Text="Permissions" Icon="@Icons.Material.Filled.Lock">
                                    <PermissionsPanel ResourceId="@configuration!.Id"
                                                      ResourceType="PermissionsPanel.PermissionResource.Configuration" Title="Configuration Permissions" />

                                    @if (configuration!.UseServerManagedParameters && parameterSchemaId.HasValue)
                                    {
                                        <PermissionsPanel ResourceId="@parameterSchemaId.Value"
                                                          ResourceType="PermissionsPanel.PermissionResource.Parameter" Title="Parameter Permissions" />
                                    }
                                </MudTabPanel>
                            </MudTabs>
                        }
else if (loading)
                        {
                            <MudProgressCircular Indeterminate="true" />
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Error">Configuration not found.</MudAlert>
                        }

@code {
    [Parameter]
    public string Name { get; set; } = string.Empty;

    private ConfigurationDetails? configuration;
    private List<ConfigurationVersionDetails> versions = [];
    private bool loading = true;
    private List<int> availableConfigMajors = [];

    // Retention override state
    private bool retentionLoading = true;
    private bool retentionSaving;
    private string? retentionSaveError;
    private bool retentionOverrideActive;
    private int? retentionKeepVersions;
    private int? retentionKeepDays;
    private bool? retentionKeepReleaseVersions;

    // Parameter schema ID for permissions panel
    private Guid? parameterSchemaId;

    protected override async Task OnInitializedAsync()
    {
        await LoadConfiguration();
    }

    private async Task LoadConfiguration()
    {
        loading = true;
        try
        {
            configuration = await ConfigurationService.GetConfigurationAsync(Name);

            if (configuration != null)
            {
                versions = await ConfigurationService.GetVersionsAsync(Name) ?? [];

                UpdateMajors();
                await LoadRetentionSettings();

                parameterSchemaId = await ConfigurationService.GetParameterSchemaIdAsync(Name);
            }
        }
        finally
        {
            loading = false;
        }
    }

    private void UpdateMajors()
    {
        availableConfigMajors = versions
            .Where(v => SemanticVersion.TryParse(v.Version, out _))
            .Select(v => SemanticVersion.Parse(v.Version).Major)
            .Distinct()
            .OrderByDescending(m => m)
            .ToList();
    }

    private async Task LoadRetentionSettings()
    {
        retentionLoading = true;

        var retention = await ConfigurationService.GetRetentionSettingsAsync(configuration!.Name);
        if (retention is not null && retention.IsOverridden)
        {
            retentionOverrideActive = true;
            retentionKeepVersions = retention.KeepVersions;
            retentionKeepDays = retention.KeepDays;
            retentionKeepReleaseVersions = retention.KeepReleaseVersions;
        }
        else
        {
            retentionOverrideActive = false;
            retentionKeepVersions = null;
            retentionKeepDays = null;
            retentionKeepReleaseVersions = null;
        }

        retentionLoading = false;
    }

    private async Task SaveRetentionSettings()
    {
        retentionSaveError = null;
        retentionSaving = true;
        StateHasChanged();

        try
        {
            await ConfigurationService.SaveRetentionSettingsAsync(configuration!.Name, new SaveRetentionSettingsRequest
            {
                KeepVersions = retentionKeepVersions,
                KeepDays = retentionKeepDays,
                KeepReleaseVersions = retentionKeepReleaseVersions
            });

            retentionOverrideActive = retentionKeepVersions.HasValue || retentionKeepDays.HasValue
                || retentionKeepReleaseVersions.HasValue;

            Snackbar.Add("Retention settings saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            retentionSaveError = $"Error saving settings: {ex.Message}";
        }
        finally
        {
            retentionSaving = false;
        }
    }

    private async Task ResetRetentionSettings()
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Reset Retention Overrides",
            "Remove all retention overrides for this configuration and revert to the global policy?",
            yesText: "Reset",
            cancelText: "Cancel");

        if (confirmed != true)
            return;

        try
        {
            await ConfigurationService.ResetRetentionSettingsAsync(configuration!.Name);

            retentionKeepVersions = null;
            retentionKeepDays = null;
            retentionKeepReleaseVersions = null;
            retentionOverrideActive = false;

            Snackbar.Add("Retention overrides cleared. Using global policy.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error resetting settings: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenFileViewer(ConfigurationVersionDetails version, ConfigurationFileDetails file, bool editMode)
    {
        if (configuration == null)
            return;

        var parameters = new DialogParameters<FileViewerDialog>
        {
            { x => x.ConfigurationName, configuration.Name },
            { x => x.Version, version.Version },
            { x => x.FilePath, file.RelativePath },
            { x => x.ContentType, file.ContentType },
            { x => x.IsEditMode, editMode }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraExtraLarge,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<FileViewerDialog>(
            file.RelativePath,
            parameters,
            options);

        var result = await dialog.Result;

        if (result is not null && !result.Canceled && editMode)
        {
            await LoadConfiguration();
        }
    }

    private async Task DownloadSpecificFile(ConfigurationFileDetails file, ConfigurationVersionDetails version)
    {
        if (configuration == null)
            return;

        try
        {
            // Navigate to the download endpoint which will serve the file with proper headers
            var downloadUrl =
$"/api/v1/configurations/{Uri.EscapeDataString(configuration.Name)}/versions/{Uri.EscapeDataString(version.Version)}/files/{Uri.EscapeDataString(file.RelativePath)}";
            Navigation.NavigateTo(downloadUrl, forceLoad: true);

            Snackbar.Add($"Downloaded {file.RelativePath}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error downloading file: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenCreateVersionDialog()
    {
        if (configuration == null)
            return;

        var parameters = new DialogParameters<CreateVersionDialog>
        {
            { x => x.ConfigurationName, configuration.Name }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreateVersionDialog>("Create New Version", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadConfiguration();
        }
    }

    private async Task OpenCreateVersionFromExistingDialog()
    {
        if (configuration == null)
            return;

        var parameters = new DialogParameters<CreateVersionFromExistingDialog>
        {
            { x => x.ConfigurationName, configuration.Name }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreateVersionFromExistingDialog>("Create Version from Existing", parameters,
options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadConfiguration();
        }
    }

    private async Task OpenAddFilesDialog(ConfigurationVersionDetails version)
    {
        if (configuration == null)
            return;

        var parameters = new DialogParameters<AddFilesToVersionDialog>
        {
            { x => x.ConfigurationName, configuration.Name },
            { x => x.Version, version.Version }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddFilesToVersionDialog>("Upload Files to Version", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadConfiguration();
        }
    }

    private async Task OpenCreateFileDialog(ConfigurationVersionDetails version)
    {
        if (configuration == null)
            return;

        var parameters = new DialogParameters<CreateFileDialog>
        {
            { x => x.ConfigurationName, configuration.Name },
            { x => x.Version, version.Version }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreateFileDialog>("Create File", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadConfiguration();
        }
    }

    private async Task PublishVersion(ConfigurationVersionDetails version)
    {
        if (configuration == null)
            return;

        var confirmed = await DialogService.ShowMessageBox(
            "Publish Version",
            $"Are you sure you want to publish version {version.Version}? This will make it available for deployment.",
            yesText: "Publish",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            var result = await ConfigurationService.PublishVersionAsync(configuration.Name, version.Version);

            if (result.Success)
            {
                Snackbar.Add($"Version {version.Version} published successfully", Severity.Success);
                // Update the version's state directly from the returned data
                if (result.UpdatedStatus.HasValue)
                {
                    version.Status = result.UpdatedStatus.Value;
                }
                // Trigger re-render to update UI with new state
                StateHasChanged();
            }
            else if (result.CompatibilityReport != null)
            {
                // Show compatibility report dialog for breaking changes
                var options = new DialogOptions
                {
                    CloseButton = true,
                    MaxWidth = MaxWidth.Large,
                    FullWidth = true
                };
                var parameters = new DialogParameters
                {
                    ["Report"] = result.CompatibilityReport
                };
                await DialogService.ShowAsync<CompatibilityReportDialog>(
                    "Breaking Changes Detected",
                    parameters,
                    options);
            }
            else
            {
                var errorMsg = result.ErrorMessage ?? "Failed to publish version";
                Snackbar.Add(errorMsg, Severity.Error);
            }
        }
    }

    private async Task DeleteVersion(ConfigurationVersionDetails version)
    {
        if (configuration == null)
            return;

        var usageInfo = await ConfigurationService.IsVersionInUseAsync(configuration.Name, version.Version);

        if (usageInfo.IsInUse)
        {
            await DialogService.ShowMessageBox(
                "Cannot Delete Version",
                $"Version {version.Version} is currently in use and cannot be deleted:\n\n{string.Join("\n",
usageInfo.Details)}\n\nPlease remove these assignments before deleting this version.",
                yesText: "OK");

            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Delete Version",
            $"Are you sure you want to delete version {version.Version}? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            try
            {
                await ConfigurationService.DeleteVersionAsync(configuration.Name, version.Version);
                Snackbar.Add($"Version {version.Version} deleted successfully", Severity.Success);
                await LoadConfiguration();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to delete version: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteFile(ConfigurationVersionDetails version, ConfigurationFileDetails file)
    {
        if (configuration == null)
