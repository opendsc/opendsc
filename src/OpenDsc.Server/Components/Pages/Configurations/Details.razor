@page "/configurations/{Name}"
@attribute [Authorize(Policy = "configurations.read")]
@using Microsoft.EntityFrameworkCore
@using OpenDsc.Server.Services
@using NuGet.Versioning
@inject ServerDbContext Db
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject IConfigurationApiClient ApiClient

<PageTitle>@Name - Configuration</PageTitle>

@if (configuration != null)
{
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-4" OnClick="@(() => Navigation.NavigateTo("/configurations"))">
        Back to Configurations
    </MudButton>

    <MudText Typo="Typo.h4" Class="mb-4">@configuration.Name</MudText>

    <MudTabs Elevation="4" Rounded="true" Color="Color.Primary">
        <MudTabPanel Text="Versions" Icon="@Icons.Material.Filled.History">
            <MudCard Class="mt-4">
                <MudCardHeader>
                    <CardHeaderActions>
                        <MudMenu Label="New Version"
                                 Variant="Variant.Filled"
                                 Color="Color.Primary"
                                 Size="Size.Small"
                                 StartIcon="@Icons.Material.Filled.Add"
                                 EndIcon="@Icons.Material.Filled.ArrowDropDown">
                            <MudMenuItem OnClick="OpenCreateVersionDialog" Icon="@Icons.Material.Filled.Upload">
                                Upload Files
                            </MudMenuItem>
                            <MudMenuItem OnClick="OpenCreateVersionFromExistingDialog" Icon="@Icons.Material.Filled.ContentCopy">
                                Create from Existing Version
                            </MudMenuItem>
                        </MudMenu>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (versions.Any())
                {
                    <MudExpansionPanels MultiExpansion="true" Class="mt-2">
                        @foreach (var major in availableConfigMajors)
                        {
                            var majorVersions = versions
                                .Where(v => SemanticVersion.TryParse(v.Version, out _) && SemanticVersion.Parse(v.Version).Major == major)
                                .ToList();
                            var draftCount = majorVersions.Count(v => v.IsDraft);
                            var archivedCount = majorVersions.Count(v => v.IsArchived);
                            var publishedVersion = majorVersions.FirstOrDefault(v => !v.IsDraft && !v.IsArchived);

                            <MudExpansionPanel Expanded="false">
                                <TitleContent>
                                    <div class="d-flex align-center gap-2">
                                        <MudText>Version @(major)</MudText>
                                        @if (publishedVersion != null)
                                        {
                                            <MudTooltip Text="Latest published version">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success">
                                                    Published @publishedVersion.Version
                                                </MudChip>
                                            </MudTooltip>
                                        }
                                        else if (majorVersions.Any())
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">No Published</MudChip>
                                        }
                                        @if (majorVersions.Any())
                                        {
                                            <MudChip T="string" Size="Size.Small">@majorVersions.Count @(majorVersions.Count == 1 ? "version" : "versions")</MudChip>
                                        }
                                        @if (draftCount > 0)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@draftCount @(draftCount == 1 ? "draft" : "drafts")</MudChip>
                                        }
                                        @if (archivedCount > 0)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@archivedCount archived</MudChip>
                                        }
                                    </div>
                                </TitleContent>
                                <ChildContent>
                                    @foreach (var version in majorVersions)
                                    {
                                        <MudExpansionPanel Expanded="false" Class="mb-3">
                                            <TitleContent>
                                                <div class="d-flex align-center gap-2">
                                                    <MudText Typo="Typo.h6">@version.Version</MudText>
                                                    @if (version.IsDraft)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">Draft</MudChip>
                                                    }
                                                    else
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Published</MudChip>
                                                    }
                                                    @if (version.IsArchived)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">Archived</MudChip>
                                                    }
                                                    <MudChip T="string" Size="Size.Small">@version.Files.Count files</MudChip>
                                                </div>
                                                <MudText Typo="Typo.caption">Created: @version.CreatedAt.LocalDateTime.ToString("g")</MudText>
                                            </TitleContent>
                                            <ChildContent>
                                                <div class="d-flex justify-end mb-2">
                                                    @if (version.IsDraft)
                                                    {
                                                        <MudTooltip Text="Change Entry Point">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Flag"
                                                                          Size="Size.Small"
                                                                          Color="Color.Secondary"
                                                                          OnClick="@(() => OpenChangeEntryPointDialog(version))" />
                                                        </MudTooltip>
                                                        <MudMenu AnchorOrigin="Origin.BottomLeft" Dense="true">
                                                            <ActivatorContent>
                                                                <MudTooltip Text="Add Files to Draft">
                                                                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                                                                  Size="Size.Small"
                                                                                  Color="Color.Primary" />
                                                                </MudTooltip>
                                                            </ActivatorContent>
                                                            <ChildContent>
                                                                <MudMenuItem OnClick="@(() => OpenAddFilesDialog(version))" Icon="@Icons.Material.Filled.Upload">
                                                                    Upload Files
                                                                </MudMenuItem>
                                                                <MudMenuItem OnClick="@(() => OpenCreateFileDialog(version))" Icon="@Icons.Material.Filled.NoteAdd">
                                                                    Create File
                                                                </MudMenuItem>
                                                            </ChildContent>
                                                        </MudMenu>
                                                        <MudTooltip Text="Publish this draft version to make it immutable">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Publish"
                                                                          Size="Size.Small"
                                                                          Color="Color.Success"
                                                                          OnClick="@(() => PublishVersion(version))" />
                                                        </MudTooltip>
                                                    }
                                                    <MudTooltip Text="Delete Version">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                      Size="Size.Small"
                                                                      Color="Color.Error"
                                                                      OnClick="@(() => DeleteVersion(version))" />
                                                    </MudTooltip>
                                                </div>

                                                <MudTable Items="@version.Files.OrderBy(f => f.RelativePath)" Dense="true" Hover="true">
                                                    <HeaderContent>
                                                        <MudTh>File Path</MudTh>
                                                        <MudTh>Actions</MudTh>
                                                    </HeaderContent>
                                                    <RowTemplate>
                                                        <MudTd>
                                                            <div class="d-flex align-center gap-1">
                                                                @if (string.Equals(context.RelativePath, version.EntryPoint, StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    <MudTooltip Text="Entry point">
                                                                        <MudIcon Icon="@Icons.Material.Filled.Flag"
                                                                                 Size="Size.Small"
                                                                                 Color="Color.Secondary" />
                                                                    </MudTooltip>
                                                                }
                                                                <span>@context.RelativePath</span>
                                                            </div>
                                                        </MudTd>
                                                        <MudTd>
                                                            <MudTooltip Text="View File">
                                                                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                                              Size="Size.Small"
                                                                              OnClick="@(() => OpenFileViewer(version, context, false))" />
                                                            </MudTooltip>
                                                            @if (version.IsDraft)
                                                            {
                                                                <MudTooltip Text="Edit File">
                                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                                                  Size="Size.Small"
                                                                                  Color="Color.Primary"
                                                                                  OnClick="@(() => OpenFileViewer(version, context, true))" />
                                                                </MudTooltip>
                                                            }
                                                            <MudTooltip Text="Download">
                                                                <MudIconButton Icon="@Icons.Material.Filled.Download"
                                                                              Size="Size.Small"
                                                                              OnClick="@(() => DownloadSpecificFile(context, version))" />
                                                            </MudTooltip>
                                                            @if (version.IsDraft)
                                                            {
                                                                @if (!string.Equals(context.RelativePath, version.EntryPoint, StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    <MudTooltip Text="Set as Entry Point">
                                                                        <MudIconButton Icon="@Icons.Material.Filled.Flag"
                                                                                      Size="Size.Small"
                                                                                      Color="Color.Secondary"
                                                                                      OnClick="@(() => SetEntryPoint(version, context))" />
                                                                    </MudTooltip>
                                                                }
                                                                @if (string.Equals(context.RelativePath, version.EntryPoint, StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    <MudTooltip Text="Change the entry point before deleting this file">
                                                                        <span>
                                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                                          Size="Size.Small"
                                                                                          Color="Color.Error"
                                                                                          Disabled="true" />
                                                                        </span>
                                                                    </MudTooltip>
                                                                }
                                                                else
                                                                {
                                                                    <MudTooltip Text="Delete File">
                                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                                      Size="Size.Small"
                                                                                      Color="Color.Error"
                                                                                      OnClick="@(() => DeleteFile(version, context))" />
                                                                    </MudTooltip>
                                                                }
                                                            }
                                                        </MudTd>
                                                    </RowTemplate>
                                                </MudTable>
                                            </ChildContent>
                                        </MudExpansionPanel>
                                    }
                                </ChildContent>
                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">No versions found.</MudAlert>
                }
                </MudCardContent>
            </MudCard>
        </MudTabPanel>

        <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.Info">
            <MudCard Class="mt-4">
                <MudCardContent>
                    <MudSimpleTable Dense="true">
                        <tbody>
                            <tr>
                                <td><strong>Name</strong></td>
                                <td>@configuration.Name</td>
                            </tr>
                            <tr>
                                <td><strong>Description</strong></td>
                                <td>@(configuration.Description ?? "-")</td>
                            </tr>
                            <tr>
                                <td><strong>Server Managed Parameters</strong></td>
                                <td>
                                    @if (configuration.UseServerManagedParameters)
                                    {
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">Enabled</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Filled">Disabled</MudChip>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Created</strong></td>
                                <td>@configuration.CreatedAt.LocalDateTime.ToString("g")</td>
                            </tr>
                            @if (configuration.UpdatedAt.HasValue)
                            {
                                <tr>
                                    <td><strong>Updated</strong></td>
                                    <td>@configuration.UpdatedAt.Value.LocalDateTime.ToString("g")</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        </MudTabPanel>
    </MudTabs>
}
else if (loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudAlert Severity="Severity.Error">Configuration not found.</MudAlert>
}

@code {
    [Parameter]
    public string Name { get; set; } = string.Empty;

    private Configuration? configuration;
    private List<ConfigurationVersion> versions = [];
    private bool loading = true;
    private List<int> availableConfigMajors = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadConfiguration();
    }

    private async Task LoadConfiguration()
    {
        loading = true;
        try
        {
            configuration = await Db.Configurations
                .Include(c => c.Versions)
                    .ThenInclude(v => v.Files)
                .AsSplitQuery()
                .FirstOrDefaultAsync(c => c.Name == Name);

            if (configuration != null)
            {
                versions = configuration.Versions
                    .OrderByDescending(v => v.CreatedAt)
                    .ToList();

                UpdateMajors();
            }
        }
        finally
        {
            loading = false;
        }
    }

    private void UpdateMajors()
    {
        availableConfigMajors = versions
            .Where(v => SemanticVersion.TryParse(v.Version, out _))
            .Select(v => SemanticVersion.Parse(v.Version).Major)
            .Distinct()
            .OrderByDescending(m => m)
            .ToList();
    }


    private async Task OpenFileViewer(ConfigurationVersion version, ConfigurationFile file, bool editMode)
    {
        if (configuration == null)
            return;

        var parameters = new DialogParameters<FileViewerDialog>
        {
            { x => x.ConfigurationName, configuration.Name },
            { x => x.Version, version.Version },
            { x => x.FilePath, file.RelativePath },
            { x => x.ContentType, file.ContentType },
            { x => x.IsEditMode, editMode }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraExtraLarge,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<FileViewerDialog>(
            file.RelativePath,
            parameters,
            options);

        var result = await dialog.Result;

        if (result is not null && !result.Canceled && editMode)
        {
            await LoadConfiguration();
        }
    }

    private async Task DownloadSpecificFile(ConfigurationFile file, ConfigurationVersion version)
    {
        if (configuration == null)
            return;

        try
        {
            // Navigate to the download endpoint which will serve the file with proper headers
            var downloadUrl = $"/api/v1/configurations/{Uri.EscapeDataString(configuration.Name)}/versions/{Uri.EscapeDataString(version.Version)}/files/{Uri.EscapeDataString(file.RelativePath)}";
            Navigation.NavigateTo(downloadUrl, forceLoad: true);

            Snackbar.Add($"Downloaded {file.RelativePath}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error downloading file: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenCreateVersionDialog()
    {
        if (configuration == null)
            return;

        var parameters = new DialogParameters<CreateVersionDialog>
        {
            { x => x.ConfigurationName, configuration.Name }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreateVersionDialog>("Create New Version", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadConfiguration();
        }
    }

    private async Task OpenCreateVersionFromExistingDialog()
    {
        if (configuration == null)
            return;

        var parameters = new DialogParameters<CreateVersionFromExistingDialog>
        {
            { x => x.ConfigurationName, configuration.Name }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreateVersionFromExistingDialog>("Create Version from Existing", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadConfiguration();
        }
    }

    private async Task OpenAddFilesDialog(ConfigurationVersion version)
    {
        if (configuration == null)
            return;

        var parameters = new DialogParameters<AddFilesToVersionDialog>
        {
            { x => x.ConfigurationName, configuration.Name },
            { x => x.Version, version.Version }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddFilesToVersionDialog>("Upload Files to Version", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadConfiguration();
        }
    }

    private async Task OpenCreateFileDialog(ConfigurationVersion version)
    {
        if (configuration == null)
            return;

        var parameters = new DialogParameters<CreateFileDialog>
        {
            { x => x.ConfigurationName, configuration.Name },
            { x => x.Version, version.Version }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreateFileDialog>("Create File", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadConfiguration();
        }
    }

    private async Task PublishVersion(ConfigurationVersion version)
    {
        if (configuration == null)
            return;

        var confirmed = await DialogService.ShowMessageBox(
            "Publish Version",
            $"Are you sure you want to publish version {version.Version}? This will make it available for deployment.",
            yesText: "Publish",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            var result = await ApiClient.PublishVersionAsync(configuration.Name, version.Version);

            if (result.Success)
            {
                Snackbar.Add($"Version {version.Version} published successfully", Severity.Success);
                // Update the version's state directly from the returned data
                if (result.UpdatedIsDraft.HasValue)
                {
                    version.IsDraft = result.UpdatedIsDraft.Value;
                }
                // Trigger re-render to update UI with new state
                StateHasChanged();
            }
            else if (result.CompatibilityReport != null)
            {
                // Show compatibility report dialog for breaking changes
                var options = new DialogOptions
                {
                    CloseButton = true,
                    MaxWidth = MaxWidth.Large,
                    FullWidth = true
                };
                var parameters = new DialogParameters
                {
                    ["Report"] = result.CompatibilityReport
                };
                await DialogService.ShowAsync<CompatibilityReportDialog>(
                    "Breaking Changes Detected",
                    parameters,
                    options);
            }
            else
            {
                var errorMsg = result.ErrorMessage ?? "Failed to publish version";
                Snackbar.Add(errorMsg, Severity.Error);
            }
        }
    }

    private async Task DeleteVersion(ConfigurationVersion version)
    {
        if (configuration == null)
            return;

        // Check if version is in use by any nodes
        var nodesUsingVersion = await Db.NodeConfigurations
            .Where(nc => nc.ConfigurationId == configuration.Id && nc.ActiveVersion == version.Version)
            .Include(nc => nc.Node)
            .ToListAsync();

        // Check if version is in use by any composite configurations
        var compositeConfigsUsingVersion = await Db.CompositeConfigurationItems
            .Where(cci => cci.ChildConfigurationId == configuration.Id && cci.ActiveVersion == version.Version)
            .Include(cci => cci.CompositeConfigurationVersion)
                .ThenInclude(ccv => ccv.CompositeConfiguration)
            .ToListAsync();

        if (nodesUsingVersion.Any() || compositeConfigsUsingVersion.Any())
        {
            var usageDetails = new List<string>();

            if (nodesUsingVersion.Any())
            {
                usageDetails.Add($"- Nodes: {string.Join(", ", nodesUsingVersion.Select(n => n.Node.Fqdn))}");
            }

            if (compositeConfigsUsingVersion.Any())
            {
                var compositeNames = compositeConfigsUsingVersion
                    .Select(c => $"{c.CompositeConfigurationVersion.CompositeConfiguration.Name} v{c.CompositeConfigurationVersion.Version}")
                    .Distinct();
                usageDetails.Add($"- Composite Configurations: {string.Join(", ", compositeNames)}");
            }

            await DialogService.ShowMessageBox(
                "Cannot Delete Version",
                $"Version {version.Version} is currently in use and cannot be deleted:\n\n{string.Join("\n", usageDetails)}\n\nPlease remove these assignments before deleting this version.",
                yesText: "OK");

            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Delete Version",
            $"Are you sure you want to delete version {version.Version}? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            var success = await ApiClient.DeleteVersionAsync(configuration.Name, version.Version);

            if (success)
            {
                Snackbar.Add($"Version {version.Version} deleted successfully", Severity.Success);

                await LoadConfiguration();
            }
            else
            {
                Snackbar.Add("Failed to delete version", Severity.Error);
            }
        }
    }

    private async Task DeleteFile(ConfigurationVersion version, ConfigurationFile file)
    {
        if (configuration == null)
            return;

        var confirmed = await DialogService.ShowMessageBox(
            "Delete File",
            $"Are you sure you want to delete '{file.RelativePath}' from version {version.Version}?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            var success = await ApiClient.DeleteFileAsync(configuration.Name, version.Version, file.RelativePath);

            if (success)
            {
                Snackbar.Add($"File '{file.RelativePath}' deleted successfully", Severity.Success);
                await LoadConfiguration();
            }
            else
            {
                Snackbar.Add("Failed to delete file", Severity.Error);
            }
        }
    }

    private async Task SetEntryPoint(ConfigurationVersion version, ConfigurationFile file)
    {
        if (configuration == null)
            return;

        var confirmed = await DialogService.ShowMessageBox(
            "Set Entry Point",
            $"Set '{file.RelativePath}' as the entry point for version {version.Version}?",
            yesText: "Set Entry Point",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            var success = await ApiClient.ChangeVersionEntryPointAsync(configuration.Name, version.Version, file.RelativePath);

            if (success)
            {
                Snackbar.Add($"Entry point changed to '{file.RelativePath}'", Severity.Success);
                await LoadConfiguration();
            }
            else
            {
                Snackbar.Add("Failed to change entry point", Severity.Error);
            }
        }
    }

    private async Task OpenChangeEntryPointDialog(ConfigurationVersion version)
    {
        if (configuration == null)
            return;

        if (version.Files.Count <= 1)
        {
            await DialogService.ShowMessageBox(
                "Change Entry Point",
                "The version must have more than one file to change the entry point.",
                yesText: "OK");
            return;
        }

        var parameters = new DialogParameters<ChangeEntryPointDialog>
        {
            { d => d.ConfigurationName, configuration.Name },
            { d => d.VersionNumber, version.Version },
            { d => d.CurrentEntryPoint, version.EntryPoint },
            { d => d.AvailableFiles, version.Files.Select(f => f.RelativePath).OrderBy(p => p).ToList() },
            { d => d.OnEntryPointChanged, EventCallback.Factory.Create(this, LoadConfiguration) }
        };

        await DialogService.ShowAsync<ChangeEntryPointDialog>("Change Entry Point", parameters);
    }
}
