@using Microsoft.EntityFrameworkCore
@using NuGet.Versioning
@using OpenDsc.Server.Services
@inject ServerDbContext Db
@inject IConfigurationApiClient ApiClient
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-3">
            Create a new version from an existing version for <strong>@ConfigurationName</strong>
        </MudText>

        <MudSelect T="string"
                   @bind-Value="sourceVersion"
                   Label="Source Version"
                   Variant="Variant.Outlined"
                   Required="true"
                   Class="mb-3"
                   HelperText="Select the version to copy files from">
            @foreach (var version in availableVersions)
            {
                <MudSelectItem Value="@version.Version">
                    <div class="d-flex align-center gap-2">
                        <span>Version @version.Version</span>
                        @if (version.IsDraft)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Draft</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Published</MudChip>
                        }
                        <MudChip T="string" Size="Size.Small">@version.Files.Count files</MudChip>
                    </div>
                </MudSelectItem>
            }
        </MudSelect>

        <MudTextField @bind-Value="newVersion"
                      Label="New Version"
                      Variant="Variant.Outlined"
                      Required="true"
                      Class="mb-3"
                      Immediate="true"
                      Error="@(!string.IsNullOrWhiteSpace(newVersion) && !SemanticVersion.TryParse(newVersion, out _))"
                      ErrorText="Version must follow semantic versioning (e.g., 1.0.0, 2.1.3-alpha, 1.0.0-beta+001)"
                      HelperText="Semantic version: major.minor.patch[-prerelease][+metadata]" />

        <MudSwitch @bind-Value="isDraft"
                   Label="Save as Draft"
                   Color="Color.Info"
                   Class="mb-3" />
        <MudText Typo="Typo.caption" Class="mb-3" Color="Color.Secondary">
            When unchecked, the version will be published immediately and become immutable.
        </MudText>

        @if (!string.IsNullOrWhiteSpace(validationError))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@validationError</MudAlert>
        }

        @if (isLoading)
        {
            <MudProgressLinear Indeterminate="true" Class="mt-3" />
            <MudText Typo="Typo.caption" Class="mt-2">Copying files...</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsValid() || isSubmitting || isLoading)">
            @if (isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <text>Create Version</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public string ConfigurationName { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnVersionCreated { get; set; }

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private string sourceVersion = string.Empty;
    private string newVersion = string.Empty;
    private bool isDraft = true;
    private bool isSubmitting = false;
    private bool isLoading = true;
    private string? validationError;
    private List<ConfigurationVersion> availableVersions = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadVersions();
    }

    private async Task LoadVersions()
    {
        try
        {
            var config = await Db.Configurations
                .Include(c => c.Versions)
                .ThenInclude(v => v.Files)
                .FirstOrDefaultAsync(c => c.Name == ConfigurationName);

            if (config != null)
            {
                availableVersions = config.Versions
                    .OrderByDescending(v => v.CreatedAt)
                    .ToList();

                // Select the most recent version by default
                if (availableVersions.Any())
                {
                    sourceVersion = availableVersions.First().Version;
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading versions: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool IsValid()
    {
        if (string.IsNullOrWhiteSpace(sourceVersion) || string.IsNullOrWhiteSpace(newVersion))
        {
            return false;
        }

        if (!SemanticVersion.TryParse(newVersion, out _))
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(validationError);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        if (!IsValid())
            return;

        isSubmitting = true;
        validationError = null;

        try
        {
            var success = await ApiClient.CreateVersionFromExistingAsync(
                ConfigurationName,
                sourceVersion,
                newVersion,
                isDraft);

            if (success)
            {
                Snackbar.Add($"Version {newVersion} created from {sourceVersion}", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
                await OnVersionCreated.InvokeAsync();
            }
            else
            {
                validationError = "Failed to create version. Please check server logs.";
            }
        }
        catch (Exception ex)
        {
            validationError = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
