@page "/reports"
@attribute [Authorize(Policy = ReportPermissions.Read)]
@inject IReportService ReportService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using OpenDsc.Contracts.Reports

<PageTitle>Compliance Reports</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Compliance Reports</MudText>

<MudCard>
    <MudCardContent>
        <MudGrid Class="mb-4">
            <MudItem xs="12" md="4">
                <MudSelect T="Guid?" Label="Filter by Node" Value="@selectedNodeId" Clearable="true"
                           ValueChanged="@((Guid? value) => OnNodeFilterChanged(value))">
                    @foreach (var node in nodes)
                    {
                        <MudSelectItem T="Guid?" Value="@node.Id">@node.Fqdn</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="string" Label="Filter by Status" Value="@selectedStatus" Clearable="true"
                           ValueChanged="@((string value) => OnStatusFilterChanged(value))">
                    <MudSelectItem Value="@("Compliant")">Compliant</MudSelectItem>
                    <MudSelectItem Value="@("NonCompliant")">Non-Compliant</MudSelectItem>
                    <MudSelectItem Value="@("Error")">Error</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudDateRangePicker @bind-DateRange="_reportDateRange" @bind-DateRange:after="ApplyFilters"
                                    Label="Date range" Variant="Variant.Outlined" DateFormat="yyyy-MM-dd" />
            </MudItem>

        </MudGrid>

        <MudDataGrid T="ReportSummary" Items="@filteredReports" Loading="@isLoading" Hover="true" Dense="true">
            <Columns>
                <PropertyColumn Property="x => x.NodeFqdn" Title="Node" />
                <PropertyColumn Property="x => x.Operation" Title="Operation" />
                <PropertyColumn Property="x => x.Timestamp" Title="Timestamp">
                    <CellTemplate>
                        @context.Item.Timestamp.LocalDateTime.ToString("g")
                    </CellTemplate>
                </PropertyColumn>
                <TemplateColumn Title="Status">
                    <CellTemplate>
                        @if (context.Item.HadErrors)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Error</MudChip>
                        }
                        else if (context.Item.InDesiredState)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Compliant</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Non-Compliant</MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn>
                    <CellTemplate>
                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                   OnClick="@(() => ViewDetails(context.Item.Id))">
                            View Details
                        </MudButton>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="ReportSummary" PageSizeOptions="@(new int[] { 10, 25, 50, 100 })" />
            </PagerContent>
        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private List<NodeOption> nodes = [];
    private List<ReportSummary> allReports = [];
    private List<ReportSummary> filteredReports = [];
    private bool isLoading = true;
    private Guid? selectedNodeId;
    private string? selectedStatus;
    private MudBlazor.DateRange _reportDateRange = new(DateTime.Today.AddDays(-7), DateTime.Today);

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            allReports = (await ReportService.GetReportsAsync()).ToList();
            nodes = allReports
                .GroupBy(r => new { r.NodeId, r.NodeFqdn })
                .Select(g => new NodeOption { Id = g.Key.NodeId, Fqdn = g.Key.NodeFqdn })
                .OrderBy(n => n.Fqdn)
                .ToList();

            filteredReports = allReports;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading reports: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        filteredReports = allReports.Where(r =>
        {
            if (selectedNodeId.HasValue && r.NodeId != selectedNodeId.Value)
                return false;

            if (!string.IsNullOrEmpty(selectedStatus))
            {
                var matchesStatus = selectedStatus switch
                {
                    "Compliant" => r.InDesiredState && !r.HadErrors,
                    "NonCompliant" => !r.InDesiredState && !r.HadErrors,
                    "Error" => r.HadErrors,
                    _ => true
                };
                if (!matchesStatus)
                    return false;
            }

            if (_reportDateRange?.Start.HasValue == true && r.Timestamp.LocalDateTime.Date < _reportDateRange.Start.Value.Date)
                return false;
            if (_reportDateRange?.End.HasValue == true && r.Timestamp.LocalDateTime.Date > _reportDateRange.End.Value.Date)
                return false;

            return true;
        }).ToList();
    }

    private void OnNodeFilterChanged(Guid? value)
    {
        selectedNodeId = value;
        ApplyFilters();
    }

    private void OnStatusFilterChanged(string? value)
    {
        selectedStatus = value;
        ApplyFilters();
    }



    private void ViewDetails(Guid id)
    {
        Navigation.NavigateTo($"/reports/{id}");
    }

    private sealed class NodeOption
    {
        public Guid Id { get; set; }
        public string NodeFqdn { get; set; } = string.Empty;
        public string Fqdn
        {
            get => NodeFqdn;
            set => NodeFqdn = value;
        }
    }
}
