    private List<ScopeValue> GetScopeValuesForType(Guid scopeTypeId)
    {
        return availableScopeValues
            .Where(sv => sv.ScopeTypeId == scopeTypeId)
            .ToList();
    }

    private List<string> GetScopeValueTextsForType(Guid scopeTypeId)
    {
        return availableScopeValues
            .Where(sv => sv.ScopeTypeId == scopeTypeId)
            .Select(sv => sv.Value)
            .Distinct()
            .OrderBy(v => v)
            .ToList();
    }

    private Task<IEnumerable<string>?> SearchScopeValueTexts(string value, CancellationToken token)
    {
        IEnumerable<string> list = selectedScopeTypeId.HasValue
            ? GetScopeValueTextsForType(selectedScopeTypeId.Value)
            : Array.Empty<string>();
        if (!string.IsNullOrWhiteSpace(value))
        {
            list = list.Where(v => v.Contains(value, StringComparison.OrdinalIgnoreCase));
        }
        return Task.FromResult<IEnumerable<string>?>(list);
    }
    private async Task AddTag()
    {
        if (node == null || !selectedScopeTypeId.HasValue)
            return;

        var currentType = availableScopeTypes.FirstOrDefault(st => st.Id == selectedScopeTypeId.Value);
        var isRestricted = currentType?.ValueMode == ScopeValueMode.Restricted;
        var isNode = currentType?.Name == "Node";
        var isUnrestricted = !isRestricted && !isNode;


        if (!isUnrestricted && !selectedScopeValueId.HasValue)
            return; // nothing selected for non-unrestricted type
        if (isUnrestricted && string.IsNullOrWhiteSpace(selectedScopeValueText))
            return;

        try
        {
            // resolve the scope value identifier, creating a new ScopeValue record if necessary
            Guid scopeValueId;
            if (isUnrestricted)
            {
                var text = selectedScopeValueText!.Trim();
                var existingValue = await Db.ScopeValues
                    .FirstOrDefaultAsync(sv => sv.ScopeTypeId == selectedScopeTypeId.Value && sv.Value == text);
                if (existingValue == null)
                {
                    existingValue = new ScopeValue
                    {
                        Id = Guid.NewGuid(),
                        ScopeTypeId = selectedScopeTypeId.Value,
                        Value = text,
                        CreatedAt = DateTimeOffset.UtcNow
                    };
                    Db.ScopeValues.Add(existingValue);
                    await Db.SaveChangesAsync();
                    availableScopeValues.Add(existingValue);
                }
                scopeValueId = existingValue.Id;
            }
            else
            {
                scopeValueId = selectedScopeValueId!.Value;
            }

            if (editingTag != null)
            {
                // if the value didn't change, nothing to do
                if (editingTag.ScopeValueId == scopeValueId)
                {
                    CancelAddOrEdit();
                    return;
                }

                Db.NodeTags.Remove(editingTag);
                await Db.SaveChangesAsync();

                var newTag = new NodeTag
                {
                    NodeId = Id,
                    ScopeValueId = scopeValueId,
                    AssignedAt = DateTimeOffset.UtcNow
                };
                Db.NodeTags.Add(newTag);
                await Db.SaveChangesAsync();
                Snackbar.Add("Tag updated successfully", Severity.Success);
            }
            else
            {
                if (selectedScopeTypeId.HasValue && nodeTags.Any(nt => nt.ScopeValue.ScopeTypeId == selectedScopeTypeId.Value))
                {
                    Snackbar.Add("A tag for that scope type already exists.", Severity.Warning);
                    return;
                }

                var existingTag = await Db.NodeTags
                    .FirstOrDefaultAsync(nt => nt.NodeId == Id && nt.ScopeValueId == scopeValueId);

                if (existingTag != null)
                {
                    Snackbar.Add("This tag is already assigned to this node.", Severity.Warning);
                    return;
                }

                var nodeTag = new NodeTag
                {
                    NodeId = Id,
                    ScopeValueId = scopeValueId,
                    AssignedAt = DateTimeOffset.UtcNow
                };

                Db.NodeTags.Add(nodeTag);
                await Db.SaveChangesAsync();
                Snackbar.Add("Tag added successfully", Severity.Success);
            }

            await LoadTagsAsync();

            selectedScopeTypeId = null;
            selectedScopeValueId = null;
            selectedScopeValueText = null;
            showAddTag = false;
            editingTag = null;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error adding tag: {ex.Message}", Severity.Error);
        }
    }

    private async Task RemoveTag(NodeTag tag)
    {
        try
        {
            Db.NodeTags.Remove(tag);
            await Db.SaveChangesAsync();

            await LoadTagsAsync();

            Snackbar.Add("Tag removed successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error removing tag: {ex.Message}", Severity.Error);
        }
    }

    private void OnScopeTypeChanged()
    {
        // clear any previously selected value when the type changes
        selectedScopeValueId = null;
        selectedScopeValueText = null;
    }

    private void ToggleAddTag()
    {
        if (editingTag != null)
        {
            CancelAddOrEdit();
        }
        else
        {
            showAddTag = !showAddTag;
        }
    }

    private void StartEditTag(NodeTag tag)
    {
        editingTag = tag;
        showAddTag = true;
        selectedScopeTypeId = tag.ScopeValue.ScopeTypeId;
        if (IsUnrestrictedScopeType(selectedScopeTypeId.Value))
        {
            selectedScopeValueText = tag.ScopeValue.Value;
            selectedScopeValueId = null;
        }
        else
        {
            selectedScopeValueId = tag.ScopeValueId;
            selectedScopeValueText = null;
        }
    }

    private void CancelAddOrEdit()
    {
        editingTag = null;
        showAddTag = false;
        selectedScopeTypeId = null;
        selectedScopeValueId = null;
        selectedScopeValueText = null;
    }
}
