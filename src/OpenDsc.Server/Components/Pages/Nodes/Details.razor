    private async Task UnassignConfiguration()
    {
        if (node == null) return;

        try
        {
            if (nodeConfig is not null)
            {
                Db.NodeConfigurations.Remove(nodeConfig);
                nodeConfig = null;
            }

            node.ConfigurationName = null;
            selectedConfigurationName = null;
            selectedMajorVersion = null;
            selectedPrereleaseChannel = null;
            availableMajorVersions = [];
            await Db.SaveChangesAsync();

            Snackbar.Add("Configuration unassigned successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error unassigning configuration: {ex.Message}", Severity.Error);
        }
    }

    private Color GetStatusColor(NodeStatus status) => status switch
    {
        NodeStatus.Compliant => Color.Success,
        NodeStatus.NonCompliant => Color.Warning,
        NodeStatus.Error => Color.Error,
        _ => Color.Default
    };

