@using MudBlazor
@using OpenDsc.Contracts.Users
@inject IGroupService GroupService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="name" Label="Group Name" Variant="Variant.Outlined" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="description" Label="Description" Variant="Variant.Outlined" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@string.IsNullOrWhiteSpace(name)">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public EventCallback OnGroupCreated { get; set; }

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private string name = string.Empty;
    private string? description;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        try
        {
            await GroupService.CreateGroupAsync(new CreateGroupRequest
            {
                Name = name,
                Description = string.IsNullOrWhiteSpace(description) ? null : description
            });

            Snackbar.Add($"Group '{name}' created successfully", Severity.Success);
            await OnGroupCreated.InvokeAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating group: {ex.Message}", Severity.Error);
        }
    }
}
