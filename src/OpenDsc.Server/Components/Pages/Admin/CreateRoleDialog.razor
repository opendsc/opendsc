@using MudBlazor
@using OpenDsc.Contracts.Users
@using OpenDsc.Server.Authorization
@inject IRoleService RoleService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="name" Label="Role Name" Variant="Variant.Outlined" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="description" Label="Description" Variant="Variant.Outlined" Lines="2" Class="mb-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-2">Permissions:</MudText>
        <MudPaper Class="pa-3" Style="max-height: 400px; overflow-y: auto; border: 1px solid #e0e0e0;">
            <MudTreeView T="string" Items="@permissionTreeItems" SelectedValues="_selectedPermissions"
                         SelectionMode="SelectionMode.MultiSelection"
                         SelectedValuesChanged="@(values => OnSelectedPermissionsChanged(values == null ? new HashSet<string>(StringComparer.Ordinal) : new HashSet<string>(values, StringComparer.Ordinal)))"
                         CheckBoxColor="Color.Primary">
                <ItemTemplate Context="item">
                    <MudTreeViewItem T="string" Expanded="_expandedItems.Contains(item.Value!)"
                                     ExpandedChanged="@((bool e) => UpdateExpanded(item.Value!, e))" Items="item.Children"
                                     Value="item.Value" Text="@item.Text" />
                </ItemTemplate>
            </MudTreeView>
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@string.IsNullOrWhiteSpace(name)">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public EventCallback OnRoleCreated { get; set; }

    private string name = string.Empty;
    private string? description;
    private List<TreeItemData<string>> permissionTreeItems = [];
    private HashSet<string> _selectedPermissions = [];
    private HashSet<string> _expandedItems = [];

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    protected override void OnInitialized()
    {
        permissionTreeItems = PermissionHierarchyHelper.CreateTreeData(Permissions.AllScopes, []);
        _selectedPermissions = new HashSet<string>(StringComparer.Ordinal);
        _expandedItems = GetAllTreeNodeValues(permissionTreeItems).ToHashSet(StringComparer.Ordinal);
    }

    private void UpdateExpanded(string value, bool expanded)
    {
        if (expanded)
            _expandedItems.Add(value);
        else
            _expandedItems.Remove(value);
    }

    private static IEnumerable<string> GetAllTreeNodeValues(List<TreeItemData<string>> items)
    {
        foreach (var item in items)
        {
            if (item.Value != null)
            {
                yield return item.Value;
            }

            if (item.Children?.Count > 0)
            {
                foreach (var childValue in GetAllTreeNodeValues(item.Children))
                {
                    yield return childValue;
                }
            }
        }
    }

    private Task OnSelectedPermissionsChanged(HashSet<string> values)
    {
        _selectedPermissions = values ?? new();
        return Task.CompletedTask;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        try
        {
            var permissions = _selectedPermissions.OrderBy(p => p).ToArray();

            await RoleService.CreateRoleAsync(new CreateRoleRequest
            {
                Name = name,
                Description = string.IsNullOrWhiteSpace(description) ? null : description,
                Permissions = permissions
            });

            Snackbar.Add($"Role '{name}' created successfully", Severity.Success);
            await OnRoleCreated.InvokeAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating role: {ex.Message}", Severity.Error);
        }
    }
}
