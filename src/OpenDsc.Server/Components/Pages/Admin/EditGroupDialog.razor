@using MudBlazor
@using OpenDsc.Contracts.Users
@inject IGroupService GroupService
@inject IUserService UserService
@inject IRoleService RoleService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (group != null)
        {
            <MudTextField @bind-Value="group.Name" Label="Group Name" Variant="Variant.Outlined" Required="true"
                          Class="mb-3" />
            <MudTextField @bind-Value="group.Description" Label="Description" Variant="Variant.Outlined" Lines="2"
                          Class="mb-3" />

            <MudText Typo="Typo.subtitle2" Class="mb-2 mt-4">Members:</MudText>
            <MudPaper Class="pa-3 mb-3" Style="max-height: 300px; overflow-y: auto;">
                @if (availableUsers.Count == 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">No users available</MudText>
                }
                else
                {
                    @foreach (var user in availableUsers)
                    {
                        <MudCheckBox @bind-Value="@selectedMembers[user.Id]" Label="@($"{user.Username} ({user.Email})")"
                                     Dense="true" />
                    }
                }
            </MudPaper>

            <MudText Typo="Typo.subtitle2" Class="mb-2">Roles:</MudText>
            <MudPaper Class="pa-3" Style="max-height: 300px; overflow-y: auto;">
                @if (availableRoles.Count == 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">No roles available</MudText>
                }
                else
                {
                    @foreach (var role in availableRoles)
                    {
                        <MudCheckBox @bind-Value="@selectedRoles[role.Id]" Label="@role.Name" Dense="true" />
                    }
                }
            </MudPaper>
        }
        else
        {
            <MudProgressCircular Indeterminate="true" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit"
                   Disabled="@(group == null || string.IsNullOrWhiteSpace(group.Name))">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public Guid GroupId { get; set; }

    [Parameter]
    public EventCallback OnGroupUpdated { get; set; }

    private GroupDetails? group;
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private List<UserSummary> availableUsers = [];
    private List<RoleSummary> availableRoles = [];
    private Dictionary<Guid, bool> selectedMembers = new();
    private Dictionary<Guid, bool> selectedRoles = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            group = await GroupService.GetGroupAsync(GroupId);

            availableUsers = (await UserService.GetUsersAsync())
                .Where(u => u.AccountType == AccountType.User && u.IsActive)
                .ToList();

            availableRoles = (await RoleService.GetRolesAsync()).ToList();

            var existingMembers = (await GroupService.GetGroupMembersAsync(GroupId))?
                .Select(ug => ug.Id)
                .ToHashSet() ?? [];

            var existingRoles = (await GroupService.GetGroupRolesAsync(GroupId))?
                .Select(gr => gr.Id)
                .ToHashSet() ?? [];

            foreach (var user in availableUsers)
            {
                selectedMembers[user.Id] = existingMembers.Contains(user.Id);
            }

            foreach (var role in availableRoles)
            {
                selectedRoles[role.Id] = existingRoles.Contains(role.Id);
            }
        }
        catch (KeyNotFoundException)
        {
            Snackbar.Add("Group not found", Severity.Error);
            MudDialog.Cancel();
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        try
        {
            var updated = await GroupService.UpdateGroupAsync(GroupId, new UpdateGroupRequest
            {
                Name = group!.Name,
                Description = group.Description
            });

            await GroupService.SetMembersAsync(GroupId, new SetGroupMembersRequest
            {
                UserIds = selectedMembers.Where(kvp => kvp.Value).Select(kvp => kvp.Key).ToArray()
            });

            await GroupService.SetRolesAsync(GroupId, new SetGroupRolesRequest
            {
                RoleIds = selectedRoles.Where(kvp => kvp.Value).Select(kvp => kvp.Key).ToArray()
            });

            Snackbar.Add($"Group '{group.Name}' updated successfully", Severity.Success);
            await OnGroupUpdated.InvokeAsync();
        }
        catch (KeyNotFoundException)
        {
            Snackbar.Add("Group not found", Severity.Error);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating group: {ex.Message}", Severity.Error);
        }
    }
}
