@namespace OpenDsc.Server.Components.Pages
@using OpenDsc.Contracts.Users
@using OpenDsc.Server.Authorization
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">@Role.Name</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">@Role.Description</MudText>
        <MudText Typo="Typo.subtitle2" Class="mb-3">Permissions:</MudText>

        @if (_rolePermissions.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                This role has no permissions assigned.
            </MudText>
        }
        else
        {
            <MudPaper Class="pa-3" Style="max-height: 400px; overflow-y: auto; border: 1px solid #e0e0e0;">
                <MudTreeView T="string" Items="@_treeItems" SelectedValues="_selectedPermissions"
                             SelectionMode="SelectionMode.MultiSelection" CheckBoxColor="Color.Primary">
                    <ItemTemplate Context="item">
                        <MudTreeViewItem T="string" Expanded="_expandedItems.Contains(item.Value!)"
                                         ExpandedChanged="@((bool e) => UpdateExpanded(item.Value!, e))" Items="item.Children"
                                         Value="item.Value" Text="@item.Text" Disabled="true" />
                    </ItemTemplate>
                </MudTreeView>
            </MudPaper>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public RoleSummary Role { get; set; } = default!;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private List<string> _rolePermissions = [];
    private List<TreeItemData<string>> _treeItems = [];
    private HashSet<string> _selectedPermissions = [];
    private HashSet<string> _expandedItems = [];

    protected override void OnParametersSet()
    {
        _rolePermissions = Role.Permissions.ToList();

        _treeItems = PermissionHierarchyHelper.CreateTreeData(Permissions.AllScopes, _rolePermissions);
        _selectedPermissions = new HashSet<string>(_rolePermissions, StringComparer.Ordinal);
        // Expand all items by default in readonly view
        _expandedItems = GetAllTreeItemValues(_treeItems);
    }

    private HashSet<string> GetAllTreeItemValues(List<TreeItemData<string>> items)
    {
        var expanded = new HashSet<string>(StringComparer.Ordinal);
        foreach (var item in items)
        {
            if (item.Value != null)
            {
                expanded.Add(item.Value);
            }
            if (item.Children?.Count > 0)
            {
                var childExpanded = GetAllTreeItemValues(item.Children);
                foreach (var child in childExpanded)
                {
                    expanded.Add(child);
                }
            }
        }
        return expanded;
    }

    private void UpdateExpanded(string value, bool expanded)
    {
        if (expanded)
            _expandedItems.Add(value);
        else
            _expandedItems.Remove(value);
    }

    private void Close() => MudDialog.Close();
}
