@using MudBlazor
@using OpenDsc.Contracts.Users
@using OpenDsc.Server.Authorization
@inject IRoleService RoleService
@inject IGroupService GroupService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (role != null)
        {
            <MudTextField @bind-Value="role.Name" Label="Role Name" Variant="Variant.Outlined" Required="true"
                          Class="mb-3" />
            <MudTextField @bind-Value="role.Description" Label="Description" Variant="Variant.Outlined" Lines="2"
                          Class="mb-3" />

            <MudText Typo="Typo.subtitle2" Class="mb-2">Groups:</MudText>
            <MudPaper Class="pa-3 mb-3" Style="max-height: 200px; overflow-y: auto;">
                @if (availableGroups.Count == 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">No groups available</MudText>
                }
                else
                {
                    @foreach (var group in availableGroups)
                    {
                        <MudCheckBox @bind-Value="@selectedGroups[group.Id]" Label="@group.Name" Dense="true" />
                    }
                }
            </MudPaper>

            <MudText Typo="Typo.subtitle2" Class="mb-2">Permissions:</MudText>
            <MudPaper Class="pa-3" Style="max-height: 400px; overflow-y: auto; border: 1px solid #e0e0e0;">
                <MudTreeView T="string" Items="@permissionTreeItems" SelectedValues="_selectedPermissions"
                             SelectionMode="SelectionMode.MultiSelection"
                             SelectedValuesChanged="@(values => OnSelectedPermissionsChanged(values == null ? new HashSet<string>(StringComparer.Ordinal) : new HashSet<string>(values, StringComparer.Ordinal)))"
                             CheckBoxColor="Color.Primary">
                    <ItemTemplate Context="item">
                        <MudTreeViewItem T="string" Expanded="_expandedItems.Contains(item.Value!)"
                                         ExpandedChanged="@((bool e) => UpdateExpanded(item.Value!, e))" Items="item.Children"
                                         Value="item.Value" Text="@item.Text" />
                    </ItemTemplate>
                </MudTreeView>
            </MudPaper>
        }
        else
        {
            <MudProgressCircular Indeterminate="true" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit"
                   Disabled="@(role == null || string.IsNullOrWhiteSpace(role.Name))">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public Guid RoleId { get; set; }

    [Parameter]
    public EventCallback OnRoleUpdated { get; set; }

    private RoleDetails? role;
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private List<GroupSummary> availableGroups = [];
    private List<TreeItemData<string>> permissionTreeItems = [];
    private HashSet<string> _selectedPermissions = [];
    private HashSet<string> _expandedItems = [];
    private Dictionary<Guid, bool> selectedGroups = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            role = await RoleService.GetRoleAsync(RoleId);

            availableGroups = (await GroupService.GetGroupsAsync()).ToList();

            var existingGroupIds = (await RoleService.GetGroupsForRoleAsync(RoleId))?
                .Select(g => g.Id)
                .ToHashSet() ?? [];

            foreach (var group in availableGroups)
            {
                selectedGroups[group.Id] = existingGroupIds.Contains(group.Id);
            }

            var existingPermissions = role.Permissions?.ToList() ?? [];

            permissionTreeItems = PermissionHierarchyHelper.CreateTreeData(Permissions.AllScopes, existingPermissions);
            _selectedPermissions = new HashSet<string>(existingPermissions, StringComparer.Ordinal);
            _expandedItems = GetAllTreeNodeValues(permissionTreeItems).ToHashSet(StringComparer.Ordinal);
        }
        catch (KeyNotFoundException)
        {
            Snackbar.Add("Role not found", Severity.Error);
            MudDialog.Cancel();
        }
    }

    private void UpdateExpanded(string value, bool expanded)
    {
        if (expanded)
            _expandedItems.Add(value);
        else
            _expandedItems.Remove(value);
    }

    private static IEnumerable<string> GetAllTreeNodeValues(List<TreeItemData<string>> items)
    {
        foreach (var item in items)
        {
            if (item.Value != null)
            {
                yield return item.Value;
            }

            if (item.Children?.Count > 0)
            {
                foreach (var childValue in GetAllTreeNodeValues(item.Children))
                {
                    yield return childValue;
                }
            }
        }
    }

    private Task OnSelectedPermissionsChanged(HashSet<string> values)
    {
        _selectedPermissions = values ?? new();
        return Task.CompletedTask;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        try
        {
            var permissions = _selectedPermissions.OrderBy(p => p).ToArray();

            var updated = await RoleService.UpdateRoleAsync(RoleId, new UpdateRoleRequest
            {
                Name = role!.Name,
                Description = role.Description,
                Permissions = permissions
            });

            await RoleService.SetGroupsForRoleAsync(RoleId, new SetRoleGroupsRequest
            {
                GroupIds = selectedGroups
                    .Where(kvp => kvp.Value)
                    .Select(kvp => kvp.Key)
                    .ToArray()
            });

            Snackbar.Add($"Role '{role.Name}' updated successfully", Severity.Success);
            await OnRoleUpdated.InvokeAsync();
        }
        catch (KeyNotFoundException)
        {
            Snackbar.Add("Role not found", Severity.Error);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating role: {ex.Message}", Severity.Error);
        }
    }
}
