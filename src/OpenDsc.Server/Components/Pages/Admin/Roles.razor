@using OpenDsc.Server.Authorization
@using MudBlazor
@using OpenDsc.Contracts.Users
@inject IRoleService RoleService
@inject ISnackbar Snackbar
@inject IDialogService Dialog

<MudCard Class="mt-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Roles</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateRole"
                       StartIcon="@Icons.Material.Filled.Add">
                Create Role
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        <MudDataGrid T="RoleSummary" Items="@roles" Hover="true" Dense="true" Loading="@loading"
                     SortMode="SortMode.Single">
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="Name" />
                <PropertyColumn Property="x => x.Description" Title="Description" />
                <TemplateColumn Title="Type" SortBy="@(x => x.IsSystemRole)">
                    <CellTemplate>
                        @if (context.Item.IsSystemRole)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">System</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">User</MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Permissions" SortBy="@(x => GetPermissionCount(x.Permissions))">
                    <CellTemplate>@GetPermissionCount(context.Item.Permissions)</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Users" SortBy="@(x => GetRoleUserCount(x.Id))">
                    <CellTemplate>@GetRoleUserCount(context.Item.Id)</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Groups" SortBy="@(x => GetRoleGroupCount(x.Id))">
                    <CellTemplate>@GetRoleGroupCount(context.Item.Id)</CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.CreatedAt" Title="Created">
                    <CellTemplate>@context.Item.CreatedAt.LocalDateTime.ToString("g")</CellTemplate>
                </PropertyColumn>
                <TemplateColumn Title="Actions" Sortable="false">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                       OnClick="@(() => ViewRole(context.Item))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => EditRole(context.Item))" Disabled="@context.Item.IsSystemRole" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteRole(context.Item))" Disabled="@context.Item.IsSystemRole" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private List<RoleSummary> roles = [];
    private Dictionary<Guid, int> roleUserCounts = new();
    private Dictionary<Guid, int> roleGroupCounts = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadRolesAsync();
    }

    private async Task LoadRolesAsync()
    {
        loading = true;
        try
        {
            roles = (await RoleService.GetRolesAsync()).ToList();
            roleUserCounts = new Dictionary<Guid, int>(await RoleService.GetRoleUserCountsAsync());
            roleGroupCounts = new Dictionary<Guid, int>(await RoleService.GetRoleGroupCountsAsync());
        }
        finally
        {
            loading = false;
        }
    }

    private static int GetPermissionCount(string[] permissions) => permissions.Length;


    private int GetRoleUserCount(Guid roleId)
    {
        return roleUserCounts.TryGetValue(roleId, out var count) ? count : 0;
    }

    private int GetRoleGroupCount(Guid roleId)
    {
        return roleGroupCounts.TryGetValue(roleId, out var count) ? count : 0;
    }

    private async Task ViewRole(RoleSummary role)
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters<ViewRoleDialog>
        {
            { x => x.Role, role }
        };

        await Dialog.ShowAsync<ViewRoleDialog>($"View Role: {role.Name}", parameters, options);
    }

    private async Task CreateRole()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters<CreateRoleDialog>
        {
            { x => x.OnRoleCreated, EventCallback.Factory.Create(this, LoadRolesAsync) }
        };

        await Dialog.ShowAsync<CreateRoleDialog>("Create Role", parameters, options);
    }

    private async Task EditRole(RoleSummary role)
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters<EditRoleDialog>
        {
            { x => x.RoleId, role.Id },
            { x => x.OnRoleUpdated, EventCallback.Factory.Create(this, LoadRolesAsync) }
        };

        await Dialog.ShowAsync<EditRoleDialog>("Edit Role", parameters, options);
    }

    private async Task DeleteRole(RoleSummary role)
    {
        if (role.IsSystemRole)
        {
            Snackbar.Add("Cannot delete system roles", Severity.Warning);
            return;
        }

        var userCount = GetRoleUserCount(role.Id);
        var groupCount = GetRoleGroupCount(role.Id);
        var message = userCount > 0 || groupCount > 0
            ? $"Delete role '{role.Name}'? This will remove it from {userCount} user(s) and {groupCount} group(s)."
            : $"Delete role '{role.Name}'?";

        var confirmed = await Dialog.ShowMessageBox(
            "Confirm Delete",
            message,
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            try
            {
                await RoleService.DeleteRoleAsync(role.Id);
                await LoadRolesAsync();
                Snackbar.Add($"Role '{role.Name}' deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting role: {ex.Message}", Severity.Error);
            }
        }
    }
}
