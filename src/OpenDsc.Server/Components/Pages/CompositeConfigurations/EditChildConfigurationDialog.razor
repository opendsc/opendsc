@using OpenDsc.Contracts.CompositeConfigurations
@using NuGet.Versioning
@using OpenDsc.Server.Services
@inject ICompositeConfigurationService CompositeConfigService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-3">
            Editing <strong>@Item.ChildConfigurationName</strong> in version <strong>@VersionString</strong>
        </MudText>

        <MudSelect @bind-Value="selectedMajorVersion" T="int?" Label="Major Version" Variant="Variant.Outlined"
                   Class="mb-3" Required="true" HelperText="Select the major version to track">
            @foreach (var major in availableMajorVersions)
            {
                <MudSelectItem T="int?" Value="@((int?)major)">v@(major)</MudSelectItem>
            }
        </MudSelect>

        @if (!string.IsNullOrWhiteSpace(validationError))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@validationError</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsValid() || isSubmitting)">
            @if (isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <text>Save</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public string CompositeName { get; set; } = string.Empty;

    [Parameter]
    public string VersionString { get; set; } = string.Empty;

    [Parameter]
    public CompositeConfigurationItemDetails Item { get; set; } = default!;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private List<int> availableMajorVersions = [];
    private int? selectedMajorVersion;
    private bool isSubmitting;
    private string? validationError;

    protected override async Task OnInitializedAsync()
    {
        selectedMajorVersion = Item.MajorVersion;
        availableMajorVersions = await CompositeConfigService.GetAvailableMajorVersionsAsync(Item.ChildConfigurationId);
    }

    private bool IsValid() => selectedMajorVersion.HasValue;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        validationError = null;
        isSubmitting = true;

        try
        {
            await CompositeConfigService.UpdateChildAsync(Item.Id, new UpdateChildConfigurationRequest
            {
                ActiveVersion = selectedMajorVersion.HasValue ? $"{selectedMajorVersion.Value}.0.0" : null,
                Order = Item.Order
            });

            Snackbar.Add("Major version updated", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            validationError = $"Error updating major version: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}

