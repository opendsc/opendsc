@using OpenDsc.Contracts.CompositeConfigurations
@using OpenDsc.Contracts.Configurations
@using NuGet.Versioning
@using OpenDsc.Server.Services
@inject ICompositeConfigurationService CompositeConfigService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-3">
            Create a new version from an existing version for <strong>@CompositeName</strong>
        </MudText>

        <MudSelect T="string" @bind-Value="sourceVersion" Label="Source Version" Variant="Variant.Outlined"
                   Required="true" Class="mb-3" HelperText="Select the version to copy child configurations from">
            @foreach (var version in availableVersions)
            {
                <MudSelectItem Value="@version.Version">
                    <div class="d-flex align-center gap-2">
                        <span>@version.Version</span>
                        @if (version.Status == ConfigurationVersionStatus.Draft)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Draft</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Published</MudChip>
                        }
                        <MudChip T="string" Size="Size.Small">@version.Items.Count @(version.Items.Count == 1 ? "child" :
                                                                          "children")</MudChip>
                        </div>
                    </MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="newVersion" Label="New Version" Variant="Variant.Outlined" Required="true"
                          Class="mb-3" Immediate="true"
                          Error="@(!string.IsNullOrWhiteSpace(newVersion) && !SemanticVersion.TryParse(newVersion, out _))"
                          ErrorText="Version must follow semantic versioning (e.g., 1.0.0, 2.1.3-alpha, 1.0.0-beta+001)"
                          HelperText="Semantic version: major.minor.patch[-prerelease][+metadata]" />

            @if (!string.IsNullOrWhiteSpace(validationError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">@validationError</MudAlert>
            }

            @if (isLoading)
            {
                <MudProgressLinear Indeterminate="true" Class="mt-3" />
                <MudText Typo="Typo.caption" Class="mt-2">Loading versions...</MudText>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancel">Cancel</MudButton>
            <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsValid() || isSubmitting || isLoading)">
                @if (isSubmitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }
                else
                {
                    <text>Create Version</text>
                }
            </MudButton>
        </DialogActions>
    </MudDialog>

@code {
    [Parameter]
    public string CompositeName { get; set; } = string.Empty;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private List<CompositeConfigurationVersionDetails> availableVersions = [];
    private string sourceVersion = string.Empty;
    private string newVersion = string.Empty;
    private bool isSubmitting;
    private bool isLoading = true;
    private string? validationError;

    protected override async Task OnInitializedAsync()
    {
        await LoadVersions();
    }

    private async Task LoadVersions()
    {
        try
        {
            var versions = await CompositeConfigService.GetVersionsAsync(CompositeName);

            if (versions != null)
            {
                availableVersions = versions
                    .OrderByDescending(v => v.CreatedAt)
                    .ToList();

                if (availableVersions.Any())
                {
                    sourceVersion = availableVersions.First().Version;
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading versions: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool IsValid() =>
        !string.IsNullOrWhiteSpace(sourceVersion) &&
        !string.IsNullOrWhiteSpace(newVersion) &&
        SemanticVersion.TryParse(newVersion, out _);

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        if (!IsValid()) return;

        validationError = null;
        isSubmitting = true;

        try
        {
            await CompositeConfigService.CreateVersionFromExistingAsync(CompositeName, new CreateCompositeVersionFromExistingRequest
            {
                SourceVersion = sourceVersion,
                NewVersion = newVersion
            });

            Snackbar.Add($"Version '{newVersion}' created from '{sourceVersion}' as draft", Severity.Success);
            MudDialog.Close(DialogResult.Ok(newVersion));
        }
        catch (Exception ex)
        {
            validationError = $"Error creating version: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}

