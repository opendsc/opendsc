@attribute [Authorize(Policy = "settings.write")]
@inject ServerDbContext Db
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using Microsoft.EntityFrameworkCore
@using OpenDsc.Server.Entities

<MudCard Class="mt-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Scopes</MudText>
            <MudText Typo="Typo.body2">Manage scope types and their values. Higher precedence types are evaluated first.</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateScopeType" StartIcon="@Icons.Material.Filled.Add">
                Create Scope Type
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        @if (isLoading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            @foreach (var scopeType in scopeTypes)
            {
                <MudCard Class="mb-3" Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                                               Size="Size.Small"
                                               Disabled="@(scopeType.IsSystem || scopeType == scopeTypes.First() || (scopeTypes.IndexOf(scopeType) > 0 && scopeTypes[scopeTypes.IndexOf(scopeType) - 1].IsSystem))"
                                               OnClick="@(() => MoveUp(scopeType))" />
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward"
                                               Size="Size.Small"
                                               Disabled="@(scopeType.IsSystem || scopeType == scopeTypes.Last() || (scopeTypes.IndexOf(scopeType) < scopeTypes.Count - 1 && scopeTypes[scopeTypes.IndexOf(scopeType) + 1].IsSystem))"
                                               OnClick="@(() => MoveDown(scopeType))" />
                                <MudText Typo="Typo.h6">@scopeType.Name</MudText>
                                @if (scopeType.IsSystem)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">System</MudChip>
                                }
                                @if (!scopeType.IsEnabled)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Disabled</MudChip>
                                }
                                @if (scopeType.ValueMode == ScopeValueMode.Restricted)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">Restricted</MudChip>
                                }
                                else if (scopeType.Name != "Node" && scopeType.Name != "Default")
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Unrestricted</MudChip>
                                }
                                @if (scopeType.Name == "Node")
                                {
                                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Computer">@nodeCount Nodes</MudChip>
                                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Article">@scopeTypeAllParamFileCounts.GetValueOrDefault(scopeType.Id, 0) Parameter Files</MudChip>
                                }
                                else if (scopeType.Name == "Default")
                                {
                                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Article">@scopeTypeAllParamFileCounts.GetValueOrDefault(scopeType.Id, 0) Parameter Files</MudChip>
                                }
                                else
                                {
                                    var scopeNodeTotal = scopeValues.Where(sv => sv.ScopeTypeId == scopeType.Id).Sum(sv => sv.NodeTags.Count);
                                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Computer">@scopeNodeTotal Nodes</MudChip>
                                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Article">@scopeTypeAllParamFileCounts.GetValueOrDefault(scopeType.Id, 0) Parameter Files</MudChip>
                                }
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Precedence: @scopeType.Precedence</MudChip>
                            </MudStack>
                            @if (!string.IsNullOrEmpty(scopeType.Description))
                            {
                                <MudText Typo="Typo.body2">@scopeType.Description</MudText>
                            }
                        </CardHeaderContent>
                        <CardHeaderActions>
                            @if (scopeType.ValueMode == ScopeValueMode.Restricted && scopeType.Name != "Node")
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" OnClick="@(() => CreateScopeValue(scopeType))" StartIcon="@Icons.Material.Filled.Add">
                                    Add Value
                                </MudButton>
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Disabled="@(scopeType.IsSystem || scopeType.Name == "Node" || scopeType.Name == "Default")"
                                           OnClick="@(() => EditScopeType(scopeType))" />
                            <MudTooltip Text="@(scopeType.IsSystem ? "System types cannot be deleted" : (!CanDeleteScopeType(scopeType) ? "One or more values are in use; remove associated nodes/parameter files first" : null))">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               Disabled="@(scopeType.IsSystem || !CanDeleteScopeType(scopeType))"
                                               OnClick="@(() => DeleteScopeType(scopeType))" />
                            </MudTooltip>
                            @if (scopeType.IsSystem)
                            {
                                @if (scopeType.IsEnabled)
                                {
                                    var disableParamCount = scopeTypeAllParamFileCounts.GetValueOrDefault(scopeType.Id, 0);
                                    var disableBlocked = disableParamCount > 0;
                                    var disableTooltip = disableBlocked
                                        ? $"Cannot disable: {disableParamCount} parameter file(s) exist."
                                        : "Disable this scope type";
                                    <MudTooltip Text="@disableTooltip">
                                        <MudIconButton Icon="@Icons.Material.Filled.Block"
                                                       Size="Size.Small"
                                                       Color="Color.Warning"
                                                       Disabled="@disableBlocked"
                                                       OnClick="@(() => DisableScopeType(scopeType))" />
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudTooltip Text="Enable this scope type">
                                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                                       Size="Size.Small"
                                                       Color="Color.Success"
                                                       OnClick="@(() => EnableScopeType(scopeType))" />
                                    </MudTooltip>
                                }
                            }
                        </CardHeaderActions>
                    </MudCardHeader>
                    @if (scopeType.ValueMode == ScopeValueMode.Restricted)
                    {
                        var values = scopeValues.Where(sv => sv.ScopeTypeId == scopeType.Id).ToList();
                        @if (values.Any())
                        {
                            <MudCardContent>
                                <MudTable Items="@values" Dense="true" Hover="true">
                                    <HeaderContent>
                                        <MudTh>Value</MudTh>
                                        <MudTh>Description</MudTh>
                                        <MudTh>Nodes</MudTh>
                                        <MudTh>Parameter Files</MudTh>
                                        <MudTh>Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.Value</MudTd>
                                        <MudTd>@context.Description</MudTd>
                                        <MudTd>
                                            <MudChip T="string" Size="Size.Small">@context.NodeTags.Count</MudChip>
                                        </MudTd>
                                        <MudTd>
                                            <MudChip T="string" Size="Size.Small">@parameterFileCounts.GetValueOrDefault((scopeType.Id, context.Value), 0)</MudChip>
                                        </MudTd>
                                        <MudTd>
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                           Size="Size.Small"
                                                           Color="Color.Primary"
                                                           OnClick="@(() => EditScopeValue(context))" />
                                            @{
                                            bool valueHasNodes = context.NodeTags.Count > 0;
                                            bool valueHasParams = parameterFileCounts.GetValueOrDefault((scopeType.Id, context.Value), 0) > 0;
                                            bool canDelete = !valueHasNodes && !valueHasParams;
                                            string? tooltip = valueHasNodes
                                                ? "Cannot delete value while nodes are tagged"
                                                : valueHasParams
                                                    ? "Cannot delete value while parameter files reference it"
                                                    : null;
                                        }
                                        <MudTooltip Text="@tooltip">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small"
                                                           Color="Color.Error"
                                                           Disabled="@(!canDelete)"
                                                           OnClick="@(() => DeleteScopeValue(context))" />
                                        </MudTooltip>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudCardContent>
                        }
                        else
                        {
                            <MudCardContent>
                                <MudAlert Severity="Severity.Info" Dense="true">
                                    <MudText Typo="Typo.body2">No values defined. Click "Add Value" to create predefined values.</MudText>
                                </MudAlert>
                            </MudCardContent>
                        }
                    }
                    else if (scopeType.Name == "Node")
                    {
                        <MudCardContent>
                            <MudAlert Severity="Severity.Info" Dense="true">
                                <MudText Typo="Typo.body2">Node scope validates against registered nodes in the system.</MudText>
                            </MudAlert>
                        </MudCardContent>
                    }
                    else if (scopeType.Name == "Default")
                    {
                        <MudCardContent>
                            <MudAlert Severity="Severity.Info" Dense="true">
                                <MudText Typo="Typo.body2">Default scope applies globally without scope values.</MudText>
                            </MudAlert>
                        </MudCardContent>
                    }
                    else
                    {
                        var unrestrictedValues = scopeValues
                            .Where(sv => sv.ScopeTypeId == scopeType.Id)
                            .Select(sv => sv.Value)
                            .Union(parameterFileCounts.Keys
                                .Where(k => k.scopeTypeId == scopeType.Id)
                                .Select(k => k.value))
                            .OrderBy(v => v)
                            .Select(v => new
                            {
                                Value = v,
                                NodeCount = scopeValues.FirstOrDefault(sv => sv.ScopeTypeId == scopeType.Id && sv.Value == v)?.NodeTags.Count ?? 0,
                                ParameterFileCount = parameterFileCounts.GetValueOrDefault((scopeType.Id, v), 0)
                            })
                            .ToList();
                        @if (unrestrictedValues.Any())
                        {
                            <MudCardContent>
                                <MudTable Items="@unrestrictedValues" Dense="true" Hover="true">
                                    <HeaderContent>
                                        <MudTh>Value</MudTh>
                                        <MudTh>Nodes</MudTh>
                                        <MudTh>Parameter Files</MudTh>
                                        <MudTh>Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.Value</MudTd>
                                        <MudTd>
                                            <MudChip T="string" Size="Size.Small">@context.NodeCount</MudChip>
                                        </MudTd>
                                        <MudTd>
                                            <MudChip T="string" Size="Size.Small">@context.ParameterFileCount</MudChip>
                                        </MudTd>
                                        <MudTd>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small"
                                                           Color="Color.Error"
                                                           Disabled="@(context.NodeCount > 0 || context.ParameterFileCount > 0)"
                                                           OnClick="@(() => DeleteUnrestrictedValue(scopeType.Id, context.Value, context.NodeCount, context.ParameterFileCount))" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudCardContent>
                        }
                        else
                        {
                            <MudCardContent>
                                <MudAlert Severity="Severity.Info" Dense="true">
                                    <MudText Typo="Typo.body2">No values have been used yet. Values appear here when nodes are tagged or parameter files are created for this scope.</MudText>
                                </MudAlert>
                            </MudCardContent>
                        }
                    }
                </MudCard>
            }
        }
    </MudCardContent>
</MudCard>

@code {
    private List<ScopeType> scopeTypes = [];
    private List<ScopeValue> scopeValues = [];
    private Dictionary<(Guid scopeTypeId, string value), int> parameterFileCounts = [];
    private Dictionary<Guid, int> scopeTypeAllParamFileCounts = [];
    private int nodeCount = 0;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            scopeTypes = await Db.ScopeTypes
                .OrderByDescending(s => s.Precedence)
                .ToListAsync();

            scopeValues = await Db.ScopeValues
                .Include(sv => sv.NodeTags)
                .OrderBy(sv => sv.Value)
                .ToListAsync();

            var parameterFileData = await Db.ParameterFiles
                .Where(pf => pf.ScopeValue != null)
                .GroupBy(pf => new { pf.ScopeTypeId, pf.ScopeValue })
                .Select(g => new { g.Key.ScopeTypeId, ScopeValue = g.Key.ScopeValue!, Count = g.Count() })
                .ToListAsync();

            parameterFileCounts = parameterFileData
                .ToDictionary(x => (x.ScopeTypeId, x.ScopeValue), x => x.Count);

            nodeCount = await Db.Nodes.CountAsync();

            var allParamFileTotals = await Db.ParameterFiles
                .GroupBy(pf => pf.ScopeTypeId)
                .Select(g => new { ScopeTypeId = g.Key, Count = g.Count() })
                .ToListAsync();
            scopeTypeAllParamFileCounts = allParamFileTotals.ToDictionary(x => x.ScopeTypeId, x => x.Count);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading scopes: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateScopeType()
    {
        var parameters = new DialogParameters<CreateScopeTypeDialog>
        {
            [nameof(CreateScopeTypeDialog.OnScopeTypeCreated)] = EventCallback.Factory.Create(this, LoadDataAsync)
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        await DialogService.ShowAsync<CreateScopeTypeDialog>("Create Scope Type", parameters, options);
    }

    private async Task EditScopeType(ScopeType scopeType)
    {
        var parameters = new DialogParameters<EditScopeTypeDialog>
        {
            [nameof(EditScopeTypeDialog.ScopeType)] = scopeType,
            [nameof(EditScopeTypeDialog.OnScopeTypeUpdated)] = EventCallback.Factory.Create(this, LoadDataAsync)
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        await DialogService.ShowAsync<EditScopeTypeDialog>("Edit Scope Type", parameters, options);
    }

    private async Task EditScopeValue(ScopeValue scopeValue)
    {
        var parameters = new DialogParameters<EditScopeValueDialog>
        {
            [nameof(EditScopeValueDialog.ScopeValue)] = scopeValue,
            [nameof(EditScopeValueDialog.OnScopeValueUpdated)] = EventCallback.Factory.Create(this, LoadDataAsync)
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        await DialogService.ShowAsync<EditScopeValueDialog>("Edit Scope Value", parameters, options);
    }

    private async Task CreateScopeValue(ScopeType scopeType)
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters<CreateScopeValueDialog>
        {
            [nameof(CreateScopeValueDialog.ScopeTypes)] = new List<ScopeType> { scopeType },
            [nameof(CreateScopeValueDialog.ScopeTypeId)] = scopeType.Id,
            [nameof(CreateScopeValueDialog.OnScopeValueCreated)] = EventCallback.Factory.Create(this, LoadDataAsync)
        };

        var title = scopeType.Name == "Node" ? "Add Node to Scope" : "Create Scope Value";
        await DialogService.ShowAsync<CreateScopeValueDialog>(title, parameters, options);
    }

    private async Task MoveUp(ScopeType scopeType)
    {
        var index = scopeTypes.IndexOf(scopeType);
        if (index <= 0) return;

        var previousItem = scopeTypes[index - 1];

        try
        {
            var tempPrecedence = -(scopeType.Precedence + previousItem.Precedence);
            var scopeTypePrecedence = scopeType.Precedence;
            var previousPrecedence = previousItem.Precedence;

            scopeType.Precedence = tempPrecedence;
            await Db.SaveChangesAsync();

            scopeType.Precedence = previousPrecedence;
            previousItem.Precedence = scopeTypePrecedence;
            await Db.SaveChangesAsync();

            Snackbar.Add("Scope type order updated", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating order: {ex.Message}", Severity.Error);
        }
    }

    private async Task MoveDown(ScopeType scopeType)
    {
        var index = scopeTypes.IndexOf(scopeType);
        if (index < 0 || index >= scopeTypes.Count - 1) return;

        var nextItem = scopeTypes[index + 1];

        try
        {
            var tempPrecedence = -(scopeType.Precedence + nextItem.Precedence);
            var scopeTypePrecedence = scopeType.Precedence;
            var nextPrecedence = nextItem.Precedence;

            scopeType.Precedence = tempPrecedence;
            await Db.SaveChangesAsync();

            scopeType.Precedence = nextPrecedence;
            nextItem.Precedence = scopeTypePrecedence;
            await Db.SaveChangesAsync();

            Snackbar.Add("Scope type order updated", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating order: {ex.Message}", Severity.Error);
        }
    }

    private bool CanDeleteScopeType(ScopeType scopeType)
    {
        if (scopeType.IsSystem)
            return false;

        var values = scopeValues.Where(sv => sv.ScopeTypeId == scopeType.Id).ToList();
        if (!values.Any())
        {
            if (parameterFileCounts.Keys.Any(k => k.scopeTypeId == scopeType.Id && parameterFileCounts[k] > 0))
            {
                return false;
            }

            return true;
        }

        foreach (var v in values)
        {
            if (v.NodeTags.Count > 0)
                return false;
            if (parameterFileCounts.GetValueOrDefault((scopeType.Id, v.Value), 0) > 0)
                return false;
        }

        if (parameterFileCounts.Keys.Any(k => k.scopeTypeId == scopeType.Id && !values.Any(v => v.Value == k.value) && parameterFileCounts[k] > 0))
        {
            return false;
        }

        return true;
    }

    private async Task EnableScopeType(ScopeType scopeType)
    {
        try
        {
            scopeType.IsEnabled = true;
            scopeType.UpdatedAt = DateTimeOffset.UtcNow;
            await Db.SaveChangesAsync();
            Snackbar.Add($"Scope type '{scopeType.Name}' enabled", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error enabling scope type: {ex.Message}", Severity.Error);
        }
    }

    private async Task DisableScopeType(ScopeType scopeType)
    {
        var result = await DialogService.ShowMessageBox(
            "Disable Scope Type",
            $"Are you sure you want to disable the '{scopeType.Name}' scope type? It will be excluded from parameter merging and hidden from parameter management until re-enabled.",
            yesText: "Disable",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                scopeType.IsEnabled = false;
                scopeType.UpdatedAt = DateTimeOffset.UtcNow;
                await Db.SaveChangesAsync();
                Snackbar.Add($"Scope type '{scopeType.Name}' disabled", Severity.Success);
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error disabling scope type: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteScopeType(ScopeType scopeType)
    {
        if (!CanDeleteScopeType(scopeType))
        {
            Snackbar.Add("Cannot delete scope type because one or more values are in use by nodes or parameter files.", Severity.Warning);
            return;
        }

        var result = await DialogService.ShowMessageBox(
            "Delete Scope Type",
            $"Are you sure you want to delete the scope type '{scopeType.Name}'? This will also remove all associated scope values.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                Db.ScopeTypes.Remove(scopeType);
                await Db.SaveChangesAsync();
                Snackbar.Add("Scope type deleted", Severity.Success);
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting scope type: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteScopeValue(ScopeValue scopeValue)
    {
        var fresh = await Db.ScopeValues
            .Include(sv => sv.NodeTags)
            .FirstOrDefaultAsync(sv => sv.Id == scopeValue.Id);
        if (fresh is null)
        {
            Snackbar.Add("Scope value no longer exists.", Severity.Warning);
            await LoadDataAsync();
            return;
        }

        var parameterCount = await Db.ParameterFiles
            .Where(pf => pf.ScopeTypeId == fresh.ScopeTypeId && pf.ScopeValue == fresh.Value)
            .CountAsync();

        if (parameterCount > 0)
        {
            Snackbar.Add($"Cannot delete scope value '{fresh.Value}' because {parameterCount} parameter(s) are using it.", Severity.Warning);
            return;
        }

        var nodeCount = fresh.NodeTags.Count;
        if (nodeCount > 0)
        {
            Snackbar.Add($"Cannot delete scope value '{fresh.Value}' because it is assigned to {nodeCount} node(s).", Severity.Warning);
            return;
        }
        var message = $"Delete '{fresh.Value}'?";

        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Delete",
            message,
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            try
            {
                Db.ScopeValues.Remove(scopeValue);
                await Db.SaveChangesAsync();
                await LoadDataAsync();
                Snackbar.Add("Scope value deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting scope value: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteUnrestrictedValue(Guid scopeTypeId, string value, int nodeCount, int parameterFileCount)
    {
        // this method is only called when both counts are zero, but guard anyway
        if (nodeCount > 0 || parameterFileCount > 0)
        {
            return;
        }

        var scopeValue = scopeValues.FirstOrDefault(sv => sv.ScopeTypeId == scopeTypeId && sv.Value == value);
        if (scopeValue == null)
        {
            // refresh data to clear stale entries
            await LoadDataAsync();
            return;
        }

        await DeleteScopeValue(scopeValue);
    }
}
