@attribute [Authorize(Policy = ScopePermissions.AdminOverride)]
@inject IScopeService ScopeService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using OpenDsc.Contracts.Settings

<MudCard Class="mt-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Scopes</MudText>
            <MudText Typo="Typo.body2">Manage scope types and their values. Higher precedence types are evaluated first.
            </MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateScopeType"
                       StartIcon="@Icons.Material.Filled.Add">
                Create Scope Type
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        @if (isLoading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            @foreach (var scopeType in scopeTypes)
            {
                <MudCard Class="mb-3" Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                                               Disabled="@(scopeType.IsSystem || scopeType == scopeTypes.First() || (scopeTypes.IndexOf(scopeType) > 0 && scopeTypes[scopeTypes.IndexOf(scopeType) - 1].IsSystem))"
                                               OnClick="@(() => MoveUp(scopeType))" />
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                                               Disabled="@(scopeType.IsSystem || scopeType == scopeTypes.Last() || (scopeTypes.IndexOf(scopeType) < scopeTypes.Count - 1 && scopeTypes[scopeTypes.IndexOf(scopeType) + 1].IsSystem))"
                                               OnClick="@(() => MoveDown(scopeType))" />
                                <MudText Typo="Typo.h6">@scopeType.Name</MudText>
                                @if (scopeType.IsSystem)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">System</MudChip>
                                }
                                @if (!scopeType.IsEnabled)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Disabled</MudChip>
                                }
                                @if (scopeType.ValueMode == ScopeValueMode.Restricted)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">Restricted</MudChip>
                                }
                                else if (scopeType.Name != "Node" && scopeType.Name != "Default")
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Unrestricted</MudChip>
                                }
                                @if (scopeType.Name == "Node")
                                {
                                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Computer">@nodeCount Nodes
                                    </MudChip>
                                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Article">
                                        @scopeType.ParameterFileCount Parameter Files</MudChip>
                                    }
                                else if (scopeType.Name == "Default")
                                    {
                                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Article">
                                            @scopeType.ParameterFileCount Parameter Files</MudChip>
                                        }
                                else
                                        {
                                            var scopeNodeTotal = scopeValues.Where(sv => sv.ScopeTypeId == scopeType.Id).Sum(sv =>
                                sv.NodeTagCount);
                                            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Computer">@scopeNodeTotal
                                                Nodes</MudChip>
                                                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Article">
                                                    @scopeType.ParameterFileCount Parameter Files</MudChip>
                                                }
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                                    Precedence: @scopeType.Precedence</MudChip>
                                                </MudStack>
                                                @if (!string.IsNullOrEmpty(scopeType.Description))
                                                {
                                                    <MudText Typo="Typo.body2">@scopeType.Description</MudText>
                                                }
                                            </CardHeaderContent>
                                            <CardHeaderActions>
                                                @if (scopeType.ValueMode == ScopeValueMode.Restricted && scopeType.Name != "Node")
                                                {
                                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => CreateScopeValue(scopeType))" StartIcon="@Icons.Material.Filled.Add">
                                                        Add Value
                                                    </MudButton>
                                                }
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                                               Disabled="@(scopeType.IsSystem || scopeType.Name == "Node" || scopeType.Name == "Default")"
                                                               OnClick="@(() => EditScopeType(scopeType))" />
                                                <MudTooltip
                                                    Text="@(scopeType.IsSystem ? "System types cannot be deleted" : (!CanDeleteScopeType(scopeType) ? "One or more values are in use; remove associated nodes/parameter files first" : null))">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                                   Disabled="@(scopeType.IsSystem || !CanDeleteScopeType(scopeType))"
                                                                   OnClick="@(() => DeleteScopeType(scopeType))" />
                                                </MudTooltip>
                                                @if (scopeType.IsSystem)
                                                {
                                                    @if (scopeType.IsEnabled)
                                                    {
                                                        var disableParamCount = scopeType.ParameterFileCount;
                                                        var disableBlocked = disableParamCount > 0;
                                                        var disableTooltip = disableBlocked
                                                            ? $"Cannot disable: {disableParamCount} parameter file(s) exist."
                                                            : "Disable this scope type";
                                                        <MudTooltip Text="@disableTooltip">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Block" Size="Size.Small" Color="Color.Warning"
                                                                           Disabled="@disableBlocked" OnClick="@(() => DisableScopeType(scopeType))" />
                                                        </MudTooltip>
                                                    }
                                                    else
                                                    {
                                                        <MudTooltip Text="Enable this scope type">
                                                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success"
                                                                           OnClick="@(() => EnableScopeType(scopeType))" />
                                                        </MudTooltip>
                                                    }
                                                }
                                            </CardHeaderActions>
                                        </MudCardHeader>
                                        @if (scopeType.ValueMode == ScopeValueMode.Restricted)
                                        {
                                            var values = scopeValues.Where(sv => sv.ScopeTypeId == scopeType.Id).ToList();
                                            @if (values.Any())
                                            {
                                                <MudCardContent>
                                                    <MudTable Items="@values" Dense="true" Hover="true">
                                                        <HeaderContent>
                                                            <MudTh>Value</MudTh>
                                                            <MudTh>Description</MudTh>
                                                            <MudTh>Nodes</MudTh>
                                                            <MudTh>Parameter Files</MudTh>
                                                            <MudTh>Actions</MudTh>
                                                        </HeaderContent>
                                                        <RowTemplate>
                                                            <MudTd>@context.Value</MudTd>
                                                            <MudTd>@context.Description</MudTd>
                                                            <MudTd>
                                                                <MudChip T="string" Size="Size.Small">@context.NodeTagCount</MudChip>
                                                            </MudTd>
                                                            <MudTd>
                                                                <MudChip T="string" Size="Size.Small">@context.ParameterFileCount</MudChip>
                                                            </MudTd>
                                                            <MudTd>
                                                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                                                               OnClick="@(() => EditScopeValue(context))" />
                                                                @{
                                                                    bool valueHasNodes = context.NodeTagCount > 0;
                                                                    bool valueHasParams = context.ParameterFileCount > 0;
                                                                    bool canDelete = !valueHasNodes && !valueHasParams;
                                                                    string? tooltip = valueHasNodes
                                                                        ? "Cannot delete value while nodes are tagged"
                                                                        : valueHasParams
                                                                            ? "Cannot delete value while parameter files reference it"
                                                                            : null;
                                                                }
                                                                <MudTooltip Text="@tooltip">
                                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                                   Color="Color.Error" Disabled="@(!canDelete)"
                                                                                   OnClick="@(() => DeleteScopeValue(context))" />
                                                                </MudTooltip>
                                                            </MudTd>
                                                        </RowTemplate>
                                                    </MudTable>
                                                </MudCardContent>
                                            }
                                            else
                                            {
                                                <MudCardContent>
                                                    <MudAlert Severity="Severity.Info" Dense="true">
                                                        <MudText Typo="Typo.body2">No values defined. Click "Add Value" to create predefined values.
                                                        </MudText>
                                                    </MudAlert>
                                                </MudCardContent>
                                            }
                                        }
                                        else if (scopeType.Name == "Node")
                                        {
                                            <MudCardContent>
                                                <MudAlert Severity="Severity.Info" Dense="true">
                                                    <MudText Typo="Typo.body2">Node scope validates against registered nodes in the system.</MudText>
                                                </MudAlert>
                                            </MudCardContent>
                                        }
                                        else if (scopeType.Name == "Default")
                                        {
                                            <MudCardContent>
                                                <MudAlert Severity="Severity.Info" Dense="true">
                                                    <MudText Typo="Typo.body2">Default scope applies globally without scope values.</MudText>
                                                </MudAlert>
                                            </MudCardContent>
                                        }
                                        else
                                        {
                                            var unrestrictedValues = scopeValues
                                                .Where(sv => sv.ScopeTypeId == scopeType.Id)
                                                .OrderBy(sv => sv.Value)
                                                .ToList();
                                            @if (unrestrictedValues.Any())
                                            {
                                                <MudCardContent>
                                                    <MudTable Items="@unrestrictedValues" Dense="true" Hover="true">
                                                        <HeaderContent>
                                                            <MudTh>Value</MudTh>
                                                            <MudTh>Nodes</MudTh>
                                                            <MudTh>Parameter Files</MudTh>
                                                            <MudTh>Actions</MudTh>
                                                        </HeaderContent>
                                                        <RowTemplate>
                                                            <MudTd>@context.Value</MudTd>
                                                            <MudTd>
                                                                <MudChip T="string" Size="Size.Small">@context.NodeTagCount</MudChip>
                                                            </MudTd>
                                                            <MudTd>
                                                                <MudChip T="string" Size="Size.Small">@context.ParameterFileCount</MudChip>
                                                            </MudTd>
                                                            <MudTd>
                                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                                               Disabled="@(context.NodeTagCount > 0 || context.ParameterFileCount > 0)"
                                                                               OnClick="@(() => DeleteUnrestrictedValue(context))" />
                                                            </MudTd>
                                                        </RowTemplate>
                                                    </MudTable>
                                                </MudCardContent>
                                            }
                                            else
                                            {
                                                <MudCardContent>
                                                    <MudAlert Severity="Severity.Info" Dense="true">
                                                        <MudText Typo="Typo.body2">No values have been used yet. Values appear here when nodes are tagged or
                                                            parameter files are created for this scope.</MudText>
                                                        </MudAlert>
                                                    </MudCardContent>
                                                }
                                            }
                                        </MudCard>
                                    }
                                }
                            </MudCardContent>
                        </MudCard>

@code {
    private List<ScopeTypeDetails> scopeTypes = [];
    private List<ScopeValueDetails> scopeValues = [];
    private int nodeCount = 0;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            var summary = await ScopeService.GetScopeSummaryAsync();
            scopeTypes = summary.ScopeTypes.OrderByDescending(st => st.Precedence).ToList();
            scopeValues = summary.ScopeValues.OrderBy(sv => sv.Value).ToList();
            nodeCount = summary.NodeCount;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading scopes: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateScopeType()
    {
        var parameters = new DialogParameters<CreateScopeTypeDialog>
        {
            [nameof(CreateScopeTypeDialog.OnScopeTypeCreated)] = EventCallback.Factory.Create(this, LoadDataAsync)
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        await DialogService.ShowAsync<CreateScopeTypeDialog>("Create Scope Type", parameters, options);
    }

    private async Task EditScopeType(ScopeTypeDetails scopeType)
    {
        var parameters = new DialogParameters<EditScopeTypeDialog>
        {
            [nameof(EditScopeTypeDialog.ScopeType)] = scopeType,
            [nameof(EditScopeTypeDialog.OnScopeTypeUpdated)] = EventCallback.Factory.Create(this, LoadDataAsync)
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        await DialogService.ShowAsync<EditScopeTypeDialog>("Edit Scope Type", parameters, options);
    }

    private async Task EditScopeValue(ScopeValueDetails scopeValue)
    {
        var parameters = new DialogParameters<EditScopeValueDialog>
        {
            [nameof(EditScopeValueDialog.ScopeValue)] = scopeValue,
            [nameof(EditScopeValueDialog.OnScopeValueUpdated)] = EventCallback.Factory.Create(this, LoadDataAsync)
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        await DialogService.ShowAsync<EditScopeValueDialog>("Edit Scope Value", parameters, options);
    }

    private async Task CreateScopeValue(ScopeTypeDetails scopeType)
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters<CreateScopeValueDialog>
        {
            [nameof(CreateScopeValueDialog.ScopeType)] = scopeType,
            [nameof(CreateScopeValueDialog.OnScopeValueCreated)] = EventCallback.Factory.Create(this, LoadDataAsync)
        };

        var title = scopeType.Name == "Node" ? "Add Node to Scope" : "Create Scope Value";
        await DialogService.ShowAsync<CreateScopeValueDialog>(title, parameters, options);
    }

    private async Task MoveUp(ScopeTypeDetails scopeType)
    {
        var index = scopeTypes.IndexOf(scopeType);
        if (index <= 0) return;

        var reordered = scopeTypes.ToList();
        reordered.RemoveAt(index);
        reordered.Insert(index - 1, scopeType);

        try
        {
            var request = new ReorderScopeTypesRequest { ScopeTypeIds = reordered.Select(st => st.Id).ToList() };
            var updated = await ScopeService.ReorderScopeTypesAsync(request);
            scopeTypes = updated.OrderByDescending(st => st.Precedence).ToList();
            Snackbar.Add("Scope type order updated", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating order: {ex.Message}", Severity.Error);
        }
    }

    private async Task MoveDown(ScopeTypeDetails scopeType)
    {
        var index = scopeTypes.IndexOf(scopeType);
        if (index < 0 || index >= scopeTypes.Count - 1) return;

        var reordered = scopeTypes.ToList();
        reordered.RemoveAt(index);
        reordered.Insert(index + 1, scopeType);

        try
        {
            var request = new ReorderScopeTypesRequest { ScopeTypeIds = reordered.Select(st => st.Id).ToList() };
            var updated = await ScopeService.ReorderScopeTypesAsync(request);
            scopeTypes = updated.OrderByDescending(st => st.Precedence).ToList();
            Snackbar.Add("Scope type order updated", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating order: {ex.Message}", Severity.Error);
        }
    }

    private bool CanDeleteScopeType(ScopeTypeDetails scopeType)
    {
        if (scopeType.IsSystem)
            return false;

        if (scopeType.ParameterFileCount > 0)
            return false;

        var values = scopeValues.Where(sv => sv.ScopeTypeId == scopeType.Id).ToList();
        foreach (var v in values)
        {
            if (v.NodeTagCount > 0)
                return false;
            if (v.ParameterFileCount > 0)
                return false;
        }

        return true;
    }

    private async Task EnableScopeType(ScopeTypeDetails scopeType)
    {
        try
        {
            await ScopeService.EnableScopeTypeAsync(scopeType.Id);
            Snackbar.Add($"Scope type '{scopeType.Name}' enabled", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error enabling scope type: {ex.Message}", Severity.Error);
        }
    }

    private async Task DisableScopeType(ScopeTypeDetails scopeType)
    {
        var result = await DialogService.ShowMessageBox(
            "Disable Scope Type",
            $"Are you sure you want to disable the '{scopeType.Name}' scope type? It will be excluded from parameter merging and hidden from parameter management until re-enabled.",
            yesText: "Disable",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await ScopeService.DisableScopeTypeAsync(scopeType.Id);
                Snackbar.Add($"Scope type '{scopeType.Name}' disabled", Severity.Success);
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error disabling scope type: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteScopeType(ScopeTypeDetails scopeType)
    {
        if (!CanDeleteScopeType(scopeType))
        {
            Snackbar.Add("Cannot delete scope type because one or more values are in use by nodes or parameter files.",
Severity.Warning);
            return;
        }

        var result = await DialogService.ShowMessageBox(
            "Delete Scope Type",
            $"Are you sure you want to delete the scope type '{scopeType.Name}'? This will also remove all associated scope values.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await ScopeService.DeleteScopeTypeAsync(scopeType.Id);
                Snackbar.Add("Scope type deleted", Severity.Success);
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting scope type: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteScopeValue(ScopeValueDetails scopeValue)
    {
        if (scopeValue.NodeTagCount > 0)
        {
            Snackbar.Add($"Cannot delete scope value '{scopeValue.Value}' because it is assigned to {scopeValue.NodeTagCount} node(s).",
Severity.Warning);
            return;
        }

        if (scopeValue.ParameterFileCount > 0)
        {
            Snackbar.Add($"Cannot delete scope value '{scopeValue.Value}' because {scopeValue.ParameterFileCount} parameter(s) are using it.",
Severity.Warning);
            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Delete",
            $"Delete '{scopeValue.Value}'?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            try
            {
                await ScopeService.DeleteScopeValueAsync(scopeValue.ScopeTypeId, scopeValue.Id);
                await LoadDataAsync();
                Snackbar.Add("Scope value deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting scope value: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteUnrestrictedValue(ScopeValueDetails scopeValue)
    {
        await DeleteScopeValue(scopeValue);
    }
}
