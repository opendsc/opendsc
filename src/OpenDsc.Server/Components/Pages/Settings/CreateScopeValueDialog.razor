@using MudBlazor
@using OpenDsc.Contracts.Settings
@inject IScopeService ScopeService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (ScopeType == null)
        {
            <MudText Typo="Typo.body2" Color="Color.Error">No scope type selected.</MudText>
        }
        else
        {
            <MudText Typo="Typo.subtitle2" Class="mb-3">Scope Type: <strong>@ScopeType.Name</strong></MudText>
        }
        @if (isNodeScope)
        {
            <MudSelect @bind-Value="value" Label="Node" Variant="Variant.Outlined" Required="true" Class="mb-3" T="string">
                @foreach (var node in nodes)
                {
                    <MudSelectItem Value="@node.Fqdn">@node.Fqdn</MudSelectItem>
                }
            </MudSelect>
            <MudText Typo="Typo.caption" Class="mb-3">Select a node from the registered nodes in the system.</MudText>
        }
        else
        {
            <MudTextField @bind-Value="value" Label="Value" Variant="Variant.Outlined" Required="true" Class="mb-3" />
        }
        <MudTextField @bind-Value="description" Label="Description" Variant="Variant.Outlined" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsValid())">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public ScopeTypeDetails? ScopeType { get; set; }

    [Parameter]
    public EventCallback OnScopeValueCreated { get; set; }

    private Guid? scopeTypeId;
    private string value = string.Empty;
    private string? description;
    private bool isNodeScope;
    private List<ScopeNodeInfo> nodes = [];

    protected override async Task OnInitializedAsync()
    {
        if (ScopeType != null)
        {
            scopeTypeId = ScopeType.Id;
            isNodeScope = ScopeType.Name == "Node";

            if (isNodeScope)
            {
                nodes = (await ScopeService.GetScopeNodesAsync(ScopeType.Id)).ToList();
            }
        }
    }

    private bool IsValid()
    {
        var effectiveScopeTypeId = ScopeType?.Id ?? scopeTypeId;
        return effectiveScopeTypeId.HasValue && !string.IsNullOrWhiteSpace(value);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        if (!IsValid())
            return;

        var effectiveScopeTypeId = ScopeType?.Id ?? scopeTypeId;
        if (!effectiveScopeTypeId.HasValue) return;

        try
        {
            await ScopeService.CreateScopeValueAsync(
                effectiveScopeTypeId.Value,
                new CreateScopeValueRequest
                {
                    Value = value,
                    Description = string.IsNullOrWhiteSpace(description) ? null : description
                });

            Snackbar.Add("Scope value created successfully", Severity.Success);
            MudDialog.Close();
            await OnScopeValueCreated.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating scope value: {ex.Message}", Severity.Error);
        }
    }
}
