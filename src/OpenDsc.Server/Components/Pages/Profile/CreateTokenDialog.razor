@namespace OpenDsc.Server.Components.Pages
@using System.Text.Json
@using OpenDsc.Server.Authorization
@using OpenDsc.Contracts.Users
@using MudBlazor
@inject IUserService UserService
@inject IPersonalAccessTokenService PatService
@inject IUserContextService UserContext
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Token Name" Variant="Variant.Outlined" Required="true"
                      HelperText="A descriptive name to identify this token" Class="mb-3" />

        <MudDatePicker @bind-Date="_expiresAt" Label="Expiration Date (optional)" Variant="Variant.Outlined"
                       MinDate="@DateTime.Today.AddDays(1)" Clearable="true" Class="mb-3" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Scopes</MudText>
        @if (_isLoadingPermissions)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudPaper Class="pa-3 mb-1" Style="max-height: 300px; overflow-y: auto; border: 1px solid #e0e0e0;">
                <MudTreeView T="string" Items="@_treeItems" SelectedValues="_selectedScopes"
                             SelectionMode="SelectionMode.MultiSelection"
                             SelectedValuesChanged="@(values => OnSelectedValuesChanged(values == null ? new HashSet<string>(StringComparer.Ordinal) : new HashSet<string>(values, StringComparer.Ordinal)))"
                             CheckBoxColor="Color.Primary">
                    <ItemTemplate Context="item">
                        @{
                            // Only disable leaf items that user doesn't have access to
                            var isLeafItem = item.Children == null || item.Children.Count == 0;
                            var isDisabled = isLeafItem && !IsSelectableScope(item.Value!);
                        }
                        <MudTreeViewItem T="string" Expanded="_expandedItems.Contains(item.Value!)"
                                         ExpandedChanged="@((bool e) => UpdateExpanded(item.Value!, e))" Items="item.Children"
                                         Value="item.Value" Text="@item.Text" Disabled="@isDisabled" />
                    </ItemTemplate>
                </MudTreeView>
            </MudPaper>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_name) || _isLoading || _isLoadingPermissions)">
            @if (_isLoading || _isLoadingPermissions)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>@(_isLoadingPermissions ? "Loading..." : "Creating...")</span>
            }
            else
            {
                <span>Create Token</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private string _name = string.Empty;
    private DateTime? _expiresAt;
    private bool _isLoading;
    private bool _isLoadingPermissions = true;

    private List<TreeItemData<string>> _treeItems = [];
    private HashSet<string> _selectedScopes = [];
    private HashSet<string> _userAccessiblePermissions = [];
    private HashSet<string> _expandedItems = [];

    protected override async Task OnInitializedAsync()
    {
        var userId = UserContext.GetCurrentUserId();
        if (userId == null)
        {
            Snackbar.Add("Not authenticated", Severity.Error);
            MudDialog.Cancel();
            return;
        }

        try
        {
            _userAccessiblePermissions = await UserService.GetEffectivePermissionsAsync(userId.Value);
            // Only show scopes the user actually has access to
            var accessibleScopes = Permissions.AllScopes.Intersect(_userAccessiblePermissions, StringComparer.Ordinal).ToArray();
            _treeItems = PermissionHierarchyHelper.CreateTreeData(accessibleScopes, []);
            _selectedScopes = new HashSet<string>(StringComparer.Ordinal);
            // Expand all categories by default
            _expandedItems = GetAllTreeNodeValues(_treeItems).ToHashSet(StringComparer.Ordinal);
        }
        finally
        {
            _isLoadingPermissions = false;
        }
    }

    private bool IsSelectableScope(string scope)
    {
        // Only leaf nodes (actual permissions) are selectable, not category headers
        return Permissions.AllScopes.Contains(scope);
    }

    private static IEnumerable<string> GetAllTreeNodeValues(List<TreeItemData<string>> items)
    {
        foreach (var item in items)
        {
            if (item.Value != null)
            {
                yield return item.Value;
            }

            if (item.Children?.Count > 0)
            {
                foreach (var childValue in GetAllTreeNodeValues(item.Children))
                {
                    yield return childValue;
                }
            }
        }
    }

    private void UpdateExpanded(string value, bool expanded)
    {
        if (expanded)
            _expandedItems.Add(value);
        else
            _expandedItems.Remove(value);
    }

    private Task OnSelectedValuesChanged(HashSet<string> values)
    {
        _selectedScopes = values ?? new();
        return Task.CompletedTask;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        var userId = UserContext.GetCurrentUserId();
        if (userId == null)
        {
            Snackbar.Add("Not authenticated", Severity.Error);
            return;
        }

        _isLoading = true;

        try
        {
            var scopes = _selectedScopes.OrderBy(s => s).ToArray();

            DateTimeOffset? expiresAt = _expiresAt.HasValue
                ? new DateTimeOffset(_expiresAt.Value, TimeSpan.Zero)
                : null;

            var (plaintext, metadata) = await PatService.CreateTokenAsync(
                userId.Value,
                _name,
                scopes,
                expiresAt);

            MudDialog.Close(DialogResult.Ok(new CreateTokenResult(plaintext, metadata)));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create token: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    public sealed record CreateTokenResult(string PlaintextToken, PersonalAccessToken Metadata);
}
