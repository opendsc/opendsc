@namespace OpenDsc.Server.Components.Pages
@using System.Text.Json
@using OpenDsc.Server.Authorization
@using MudBlazor
@inject ServerDbContext Db
@inject IUserContextService UserContext
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_isLoadingPermissions)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudText Typo="Typo.subtitle2" Class="mb-3">Scopes</MudText>
            <MudPaper Class="pa-3" Style="max-height: 400px; overflow-y: auto; border: 1px solid #e0e0e0;">
                <MudTreeView T="string" Items="@_treeItems" SelectedValues="_selectedScopes"
                             SelectionMode="SelectionMode.MultiSelection"
                             SelectedValuesChanged="@(values => OnSelectedValuesChanged(values == null ? new HashSet<string>(StringComparer.Ordinal) : new HashSet<string>(values, StringComparer.Ordinal)))"
                             CheckBoxColor="Color.Primary">
                    <ItemTemplate Context="item">
                        @{
                            // Only disable leaf items that user doesn't have access to
                            var isLeafItem = item.Children == null || item.Children.Count == 0;
                            var isDisabled = isLeafItem && !IsSelectableScope(item.Value!);
                        }
                        <MudTreeViewItem T="string" Expanded="_expandedItems.Contains(item.Value!)"
                                         ExpandedChanged="@((bool e) => UpdateExpanded(item.Value!, e))" Items="item.Children"
                                         Value="item.Value" Text="@item.Text" Disabled="@isDisabled" />
                    </ItemTemplate>
                </MudTreeView>
            </MudPaper>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(_isLoading || _isLoadingPermissions)">
            @if (_isLoading || _isLoadingPermissions)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>@(_isLoadingPermissions ? "Loading..." : "Saving...")</span>
            }
            else
            {
                <span>Save</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public PersonalAccessToken Token { get; set; } = default!;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private List<TreeItemData<string>> _treeItems = [];
    private HashSet<string> _selectedScopes = [];
    private HashSet<string> _userAccessiblePermissions = [];
    private HashSet<string> _expandedItems = [];
    private bool _isLoading;
    private bool _isLoadingPermissions = true;

    protected override async Task OnInitializedAsync()
    {
        var userId = UserContext.GetCurrentUserId();
        if (userId == null)
        {
            Snackbar.Add("Not authenticated", Severity.Error);
            MudDialog.Cancel();
            return;
        }

        try
        {
            _userAccessiblePermissions = await RbacPermissionResolver.ResolveUserAndInternalGroupPermissionsAsync(Db, userId.Value);

            var currentScopes = new List<string>();
            try
            {
                currentScopes = JsonSerializer.Deserialize<List<string>>(Token.Scopes) ?? [];
            }
            catch { }

            _treeItems = PermissionHierarchyHelper.CreateTreeData(Permissions.AllScopes, currentScopes);
            _selectedScopes = new HashSet<string>(currentScopes, StringComparer.Ordinal);
            _expandedItems = _treeItems.Where(item => item.Value != null).Select(item =>
item.Value!).ToHashSet(StringComparer.Ordinal);
        }
        finally
        {
            _isLoadingPermissions = false;
        }
    }

    private bool IsSelectableScope(string scope)
    {
        // Only leaf nodes (actual permissions) are selectable, not category headers
        return _userAccessiblePermissions.Contains(scope) && Permissions.AllScopes.Contains(scope);
    }

    private void UpdateExpanded(string value, bool expanded)
    {
        if (expanded)
            _expandedItems.Add(value);
        else
            _expandedItems.Remove(value);
    }

    private Task OnSelectedValuesChanged(HashSet<string> values)
    {
        _selectedScopes = values ?? new();
        return Task.CompletedTask;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        // Validate that all selected scopes are accessible to the user
        var invalidScopes = _selectedScopes.Where(s => !_userAccessiblePermissions.Contains(s)).ToList();
        if (invalidScopes.Count > 0)
        {
            Snackbar.Add("You attempted to select scopes you don't have access to.", Severity.Warning);
            return;
        }

        _isLoading = true;

        try
        {
            var token = await Db.PersonalAccessTokens.FindAsync(Token.Id);
            if (token == null)
            {
                Snackbar.Add("Token not found.", Severity.Error);
                return;
            }

            token.Scopes = JsonSerializer.Serialize(_selectedScopes.OrderBy(s => s).ToArray());
            await Db.SaveChangesAsync();

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to update scopes: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
