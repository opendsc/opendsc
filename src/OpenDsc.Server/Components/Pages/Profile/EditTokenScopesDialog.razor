@namespace OpenDsc.Server.Components.Pages
@using System.Text.Json
@using OpenDsc.Contracts.Users
@using OpenDsc.Server.Authorization
@using MudBlazor
@inject IUserContextService UserContext
@inject IUserService UserService
@inject IPersonalAccessTokenService PatService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_isLoadingPermissions)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudText Typo="Typo.subtitle2" Class="mb-3">Scopes</MudText>
            <MudPaper Class="pa-3" Style="max-height: 400px; overflow-y: auto; border: 1px solid #e0e0e0;">
                <MudTreeView T="string" Items="@_treeItems" SelectedValues="_selectedScopes"
                             SelectionMode="SelectionMode.MultiSelection"
                             SelectedValuesChanged="@(values => OnSelectedValuesChanged(values == null ? new HashSet<string>(StringComparer.Ordinal) : new HashSet<string>(values, StringComparer.Ordinal)))"
                             CheckBoxColor="Color.Primary">
                    <ItemTemplate Context="item">
                        @{
                            // Only disable leaf items that user doesn't have access to
                            var isLeafItem = item.Children == null || item.Children.Count == 0;
                            var isDisabled = isLeafItem && !IsSelectableScope(item.Value!);
                        }
                        <MudTreeViewItem T="string" Expanded="_expandedItems.Contains(item.Value!)"
                                         ExpandedChanged="@((bool e) => UpdateExpanded(item.Value!, e))" Items="item.Children"
                                         Value="item.Value" Text="@item.Text" Disabled="@isDisabled" />
                    </ItemTemplate>
                </MudTreeView>
            </MudPaper>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(_isLoading || _isLoadingPermissions)">
            @if (_isLoading || _isLoadingPermissions)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>@(_isLoadingPermissions ? "Loading..." : "Saving...")</span>
            }
            else
            {
                <span>Save</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public PersonalAccessToken Token { get; set; } = default!;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private List<TreeItemData<string>> _treeItems = [];
    private HashSet<string> _selectedScopes = [];
    private HashSet<string> _userAccessiblePermissions = [];
    private HashSet<string> _expandedItems = [];
    private bool _isLoading;
    private bool _isLoadingPermissions = true;
    private Guid? _userId;

    protected override async Task OnInitializedAsync()
    {
        _userId = UserContext.GetCurrentUserId();
        if (_userId == null)
        {
            Snackbar.Add("Not authenticated", Severity.Error);
            MudDialog.Cancel();
            return;
        }

        try
        {
            _userAccessiblePermissions = await UserService.GetEffectivePermissionsAsync(_userId.Value);

            var currentScopes = new List<string>();
            try
            {
                currentScopes = JsonSerializer.Deserialize<List<string>>(Token.Scopes) ?? [];
            }
            catch { }

            // Only show scopes the user actually has access to
            var accessibleScopes = Permissions.AllScopes.Intersect(_userAccessiblePermissions, StringComparer.Ordinal).ToArray();
            _treeItems = PermissionHierarchyHelper.CreateTreeData(accessibleScopes, currentScopes);
            // Only select scopes that are both in the token and accessible to the user
            var selectableScopes = currentScopes.Where(s => accessibleScopes.Contains(s)).ToArray();
            _selectedScopes = new HashSet<string>(selectableScopes, StringComparer.Ordinal);
            // Expand all categories by default
            _expandedItems = GetAllTreeNodeValues(_treeItems).ToHashSet(StringComparer.Ordinal);
        }
        finally
        {
            _isLoadingPermissions = false;
        }
    }

    private bool IsSelectableScope(string scope)
    {
        // Only leaf nodes (actual permissions) are selectable, not category headers
        // Since we only show accessible scopes, we just need to check if it's a valid permission
        return Permissions.AllScopes.Contains(scope);
    }

    private static IEnumerable<string> GetAllTreeNodeValues(List<TreeItemData<string>> items)
    {
        foreach (var item in items)
        {
            if (item.Value != null)
            {
                yield return item.Value;
            }

            if (item.Children?.Count > 0)
            {
                foreach (var childValue in GetAllTreeNodeValues(item.Children))
                {
                    yield return childValue;
                }
            }
        }
    }

    private void UpdateExpanded(string value, bool expanded)
    {
        if (expanded)
            _expandedItems.Add(value);
        else
            _expandedItems.Remove(value);
    }

    private Task OnSelectedValuesChanged(HashSet<string> values)
    {
        _selectedScopes = values ?? new();
        return Task.CompletedTask;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _isLoading = true;

        try
        {
            await PatService.UpdateScopesAsync(Token.Id, _userId!.Value, new UpdateTokenScopesRequest
            {
                Scopes = _selectedScopes.OrderBy(s => s).ToArray()
            });

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (KeyNotFoundException)
        {
            Snackbar.Add("Token not found.", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to update scopes: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
