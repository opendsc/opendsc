@page "/login"
@rendermode InteractiveServer
@using MudBlazor
@using OpenDsc.Server.Authentication
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject IConfiguration Configuration

<MudContainer MaxWidth="MaxWidth.Small" Style="display: flex; align-items: center; justify-content: center; min-height: 100vh;">
    <MudCard Style="width: 100%; max-width: 400px;">
        <MudCardContent>
            <MudStack AlignItems="AlignItems.Center" Class="mb-4">
                <MudText Typo="Typo.h4">OpenDSC Server</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">Sign in to continue</MudText>
            </MudStack>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@errorMessage</MudAlert>
            }

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="loginModel!.Username"
                              Label="Username"
                              Variant="Variant.Outlined"
                              Required="true"
                              Class="mb-3" />

                <MudTextField @bind-Value="loginModel!.Password"
                              Label="Password"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Required="true"
                              Class="mb-4" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@isLoading">
                    @if (isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Signing in...</span>
                    }
                    else
                    {
                        <span>Sign In</span>
                    }
                </MudButton>
            </EditForm>

            @if (oidcProviders.Count > 0)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="my-4">
                    <MudDivider />
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="white-space: nowrap; padding: 0 8px;">OR</MudText>
                    <MudDivider />
                </MudStack>
                <MudStack Spacing="2">
                    @foreach (var provider in oidcProviders)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   FullWidth="true"
                                   OnClick="@(() => SignInWithProvider(provider.Name))">
                            Sign in with @provider.DisplayName
                        </MudButton>
                    }
                </MudStack>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private LoginModel loginModel = new();
    private bool isLoading = false;
    private string? errorMessage;
    private List<OidcProviderInfo> oidcProviders = [];

    protected override Task OnInitializedAsync()
    {
        oidcProviders = Configuration
            .GetSection("Authentication:OidcProviders")
            .Get<List<OidcProviderOptions>>()
            ?.Where(p => !string.IsNullOrEmpty(p.Name))
            .Select(p => new OidcProviderInfo { Name = p.Name, DisplayName = p.DisplayName ?? p.Name })
            .ToList() ?? [];

        return Task.CompletedTask;
    }

    private void SignInWithProvider(string providerName)
    {
        var uri = Navigation.Uri;
        var returnUrl = string.Empty;
        var queryIndex = uri.IndexOf('?');
        if (queryIndex >= 0)
        {
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri[queryIndex..]);
            if (query.TryGetValue("returnUrl", out var rv))
            {
                returnUrl = rv.ToString();
            }
        }

        var challengeUrl = string.IsNullOrEmpty(returnUrl)
            ? $"/api/v1/auth/oidc/{Uri.EscapeDataString(providerName)}/challenge"
            : $"/api/v1/auth/oidc/{Uri.EscapeDataString(providerName)}/challenge?returnUrl={Uri.EscapeDataString(returnUrl)}";

        Navigation.NavigateTo(challengeUrl, forceLoad: true);
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await JSRuntime.InvokeAsync<LoginResult>("loginApi.login", loginModel.Username, loginModel.Password);
            if (!result.Success)
            {
                errorMessage = result.Error ?? "Invalid username or password";
                return;
            }

            var redirectUrl = result.RequirePasswordChange ? "/change-password" : "/";
            Navigation.NavigateTo(redirectUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Login failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private sealed class LoginResult
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
        public bool RequirePasswordChange { get; set; }
    }

    private sealed class OidcProviderInfo
    {
        public string Name { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
    }
}
