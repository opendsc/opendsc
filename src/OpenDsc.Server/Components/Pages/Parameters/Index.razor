@page "/parameters"
@attribute [Authorize(Policy = "parameters.read")]
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using OpenDsc.Server.Services
@using MudBlazor
@using BlazorMonaco
@using BlazorMonaco.Editor
@inject ServerDbContext Db
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject IJsonYamlConverter JsonYamlConverter
@inject ThemeService ThemeService
@inject IJSRuntime JSRuntime

<PageTitle>Parameters</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Parameter Management</MudText>

<MudTabs Elevation="4" Rounded="true" Color="Color.Primary" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Info">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Parameter Schemas by Configuration</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadDataAsync">
                        Refresh
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @if (loading)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (groupedSchemas.Any())
                {
                    <MudExpansionPanels MultiExpansion="true" Class="mt-2">
                        @foreach (var group in groupedSchemas)
                        {
                            <MudExpansionPanel Expanded="false">
                                <TitleContent>
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.h6">@group.ConfigurationName</MudText>
                                        <MudChip T="string"
                                                 Size="Size.Small">
                                            @group.Schemas.Count
                                            @(group.Schemas.Count == 1 ? "schema" : "schemas")
                                        </MudChip>
                                    </div>
                                </TitleContent>
                                <ChildContent>
                                    <MudTable Items="@group.Schemas" Hover="true" Dense="true">
                                        <HeaderContent>
                                            <MudTh>Schema Version</MudTh>
                                            <MudTh>Parameter Files</MudTh>
                                            <MudTh>Created</MudTh>
                                            <MudTh>Actions</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>
                                                <MudText Typo="Typo.caption">@(context.SchemaVersion ?? "unknown")</MudText>
                                            </MudTd>
                                            <MudTd>
                                                <MudChip T="string" Size="Size.Small">@context.ParameterFiles.Count</MudChip>
                                            </MudTd>
                                            <MudTd>@context.CreatedAt.LocalDateTime.ToString("g")</MudTd>
                                            <MudTd>
                                                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => ViewSchema(context))">
                                                    View Schema
                                                </MudButton>
                                                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => ViewFiles(context))">
                                                    View Files
                                                </MudButton>
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                </ChildContent>
                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">No parameter schemas found.</MudAlert>
                }
            </MudCardContent>
        </MudCard>
    </MudTabPanel>

    <MudTabPanel Text="Create/Edit" Icon="@Icons.Material.Filled.Edit">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Create Parameter</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateParameterDialog">
                        Create New Parameter
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body1" Class="mb-3">
                    Create and manage parameter files for your configurations with YAML editor support.
                </MudText>
                <MudAlert Severity="Severity.Info">
                    Click "Create New Parameter" to open the parameter editor. You can specify scope type, scope value, version, and edit YAML content directly in the browser.
                </MudAlert>
            </MudCardContent>
        </MudCard>
    </MudTabPanel>

    <MudTabPanel Text="Versions" Icon="@Icons.Material.Filled.History">
        <VersionManagementPanel />
    </MudTabPanel>

    <MudTabPanel Text="Provenance" Icon="@Icons.Material.Filled.AccountTree">
        <ProvenanceVisualizationPanel />
    </MudTabPanel>
</MudTabs>

@if (selectedSchema != null && showSchemaDialog)
{
    <MudDialog @bind-Visible="showSchemaDialog" Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraLarge, FullWidth = true })">
        <DialogContent>
            <MudText Typo="Typo.h6" Class="mb-3">Schema Definition</MudText>
            <MudCard Outlined="true">
                <MudCardContent>
                    <MudText Typo="Typo.caption">Configuration: @selectedConfiguration?.Name</MudText>
                    <br />
                    <MudText Typo="Typo.caption" Class="mb-3">Schema Version: v@(selectedSchema.SchemaVersion ?? "unknown")</MudText>
                    @if (!string.IsNullOrWhiteSpace(selectedSchema.GeneratedJsonSchema))
                    {
                        <div class="d-flex justify-end mb-2">
                            <MudButtonGroup>
                                <MudButton Variant="@(schemaViewFormat == SchemaFormat.Yaml ? Variant.Filled : Variant.Text)"
                                           Color="@(schemaViewFormat == SchemaFormat.Yaml ? Color.Primary : Color.Default)"
                                           Style="@(schemaViewFormat == SchemaFormat.Yaml ? "" : "opacity: 0.6")"
                                           OnClick="@(() => SwitchSchemaFormat(SchemaFormat.Yaml))">
                                    YAML
                                </MudButton>
                                <MudButton Variant="@(schemaViewFormat == SchemaFormat.Json ? Variant.Filled : Variant.Text)"
                                           Color="@(schemaViewFormat == SchemaFormat.Json ? Color.Primary : Color.Default)"
                                           Style="@(schemaViewFormat == SchemaFormat.Json ? "" : "opacity: 0.6")"
                                           OnClick="@(() => SwitchSchemaFormat(SchemaFormat.Json))">
                                    JSON
                                </MudButton>
                            </MudButtonGroup>
                        </div>
                        <div style="height: 500px; width: 100%; border: 1px solid var(--mud-palette-lines-default);">
                            <StandaloneCodeEditor @ref="_schemaEditor"
                                                  Id="schema-viewer-editor"
                                                  ConstructionOptions="GetSchemaEditorOptions"
                                                  CssClass="monaco-editor-container" />
                        </div>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Warning">
                            No JSON schema generated for this parameter schema.
                        </MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseSchemaDialog">Close</MudButton>
        </DialogActions>
    </MudDialog>
}

@if (selectedSchema != null && showFilesDialog)
{
    <MudDialog @bind-Visible="showFilesDialog" Options="new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true }">
        <DialogContent>
            <MudText Typo="Typo.h6" Class="mb-3">Parameter Files</MudText>
            <MudText Typo="Typo.caption" Class="mb-3">Configuration: @selectedConfiguration?.Name</MudText>

            @if (selectedSchemaFiles.Any())
            {
                <MudTable Items="@selectedSchemaFiles" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Scope Type</MudTh>
                        <MudTh>Scope Value</MudTh>
                        <MudTh>Version</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Created</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.ScopeType.Name</MudTd>
                        <MudTd>@(context.ScopeValue ?? "-")</MudTd>
                        <MudTd>@context.Version</MudTd>
                        <MudTd>
                            @if (context.IsActive)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">Active</MudChip>
                            }
                            @if (context.IsDraft)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">Draft</MudChip>
                            }
                            @if (context.IsArchived)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">Archived</MudChip>
                            }
                        </MudTd>
                        <MudTd>@context.CreatedAt.LocalDateTime.ToString("g")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudAlert Severity="Severity.Info">No parameter files for this schema.</MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => { showFilesDialog = false; StateHasChanged(); })">Close</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private List<SchemaGroup> groupedSchemas = [];
    private ParameterSchema? selectedSchema;
    private Configuration? selectedConfiguration;
    private List<ParameterFile> selectedSchemaFiles = [];
    private bool showSchemaDialog;
    private bool showFilesDialog;
    private bool loading = true;
    private StandaloneCodeEditor? _schemaEditor;
    private SchemaFormat schemaViewFormat = SchemaFormat.Yaml;
    private string _currentSchemaContent = string.Empty;

    private enum SchemaFormat
    {
        Json,
        Yaml
    }

    public class SchemaGroup
    {
        public string ConfigurationName { get; set; } = string.Empty;
        public List<ParameterSchema> Schemas { get; set; } = [];
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        loading = true;
        try
        {
            var schemas = await Db.ParameterSchemas
                .Include(ps => ps.Configuration)
                .Include(ps => ps.ParameterFiles)
                .ToListAsync();

            schemas = schemas
                .OrderBy(ps => ps.Configuration.Name)
                .ThenBy(ps => ps.CreatedAt)
                .ToList();

            groupedSchemas = schemas
                .GroupBy(ps => ps.Configuration.Name)
                .Select(g => new SchemaGroup
                {
                    ConfigurationName = g.Key,
                    Schemas = g.ToList()
                })
                .ToList();
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OpenCreateParameterDialog()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreateParameterDialog>("Create Parameter", options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadDataAsync();
            Snackbar.Add("Parameter created successfully", Severity.Success);
        }
    }

    private async Task ViewSchema(ParameterSchema schema)
    {
        selectedSchema = schema;
        selectedConfiguration = schema.Configuration;
        schemaViewFormat = SchemaFormat.Yaml;
        showSchemaDialog = true;

        await Task.Delay(100);
        await UpdateSchemaEditorContent();
    }

    private async Task SwitchSchemaFormat(SchemaFormat format)
    {
        schemaViewFormat = format;
        await UpdateSchemaEditorContent();
    }

    private async Task UpdateSchemaEditorContent()
    {
        if (_schemaEditor == null || selectedSchema == null || string.IsNullOrWhiteSpace(selectedSchema.GeneratedJsonSchema))
        {
            return;
        }

        var content = schemaViewFormat == SchemaFormat.Yaml
            ? JsonYamlConverter.ConvertJsonToYaml(selectedSchema.GeneratedJsonSchema)
            : FormatJson(selectedSchema.GeneratedJsonSchema);

        _currentSchemaContent = content;
        await _schemaEditor.SetValue(content);

        var language = schemaViewFormat == SchemaFormat.Yaml ? "yaml" : "json";
        var model = await _schemaEditor.GetModel();
        if (model != null)
        {
            await Global.SetModelLanguage(JSRuntime, model, language);
        }
    }

    private string FormatJson(string json)
    {
        try
        {
            var jsonObj = System.Text.Json.JsonSerializer.Deserialize<object>(json);
            return System.Text.Json.JsonSerializer.Serialize(jsonObj, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }

    private StandaloneEditorConstructionOptions GetSchemaEditorOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = schemaViewFormat == SchemaFormat.Yaml ? "yaml" : "json",
            Value = _currentSchemaContent,
            Theme = ThemeService.IsDarkMode ? "vs-dark" : "vs",
            ReadOnly = true,
            LineNumbers = "on",
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false,
            FontSize = 14,
            FontFamily = "'Cascadia Code', 'Courier New', monospace",
            TabSize = 2,
            InsertSpaces = true,
            WordWrap = "off"
        };
    }

    private void CloseSchemaDialog()
    {
        showSchemaDialog = false;
        selectedSchema = null;
        selectedConfiguration = null;
        _currentSchemaContent = string.Empty;
    }

    private async Task ViewFiles(ParameterSchema schema)
    {
        selectedSchema = schema;
        selectedConfiguration = schema.Configuration;

        selectedSchemaFiles = await Db.ParameterFiles
            .Where(pf => pf.ParameterSchemaId == schema.Id)
            .Include(pf => pf.ScopeType)
            .OrderBy(pf => pf.ScopeType.Precedence)
            .ThenBy(pf => pf.ScopeValue)
            .ThenBy(pf => pf.Version)
            .ToListAsync();

        showFilesDialog = true;
    }
}



