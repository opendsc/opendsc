using System.Text.Json;
using System.Text.Json.Serialization;

using Json.Schema;

using OpenDsc.Resource.CommandLine;

namespace OpenDsc.Resource.{Namespace};

[DscResource("OpenDsc.{Area}/{Name}", "0.1.0", Description = "{Description}", Tags = ["{tag1}"])]
[ExitCode(0, Description = "Success")]
[ExitCode(1, Exception = typeof(Exception), Description = "Error")]
public sealed class Resource(JsonSerializerContext context)
    : DscResource<Schema>(context),
      IGettable<Schema>,
      ISettable<Schema>,
      IDeletable<Schema>,
      IExportable<Schema>
{
    public override string GetSchema()
    {
        var registry = new SchemaRegistry();
        // Note: The compiler generates the schema type name based on your project.
        // Replace {Name}_Schema with the actual generated type (e.g., Schema if single schema in project).
        var schema = registry.CreateBundle(GeneratedJsonSchemas.{Name}_Schema.BaseUri, Schema.BundleUri);
        return JsonSerializer.Serialize(schema, SourceGenerationContext.Default.JsonSchema);
    }

    public Schema Get(Schema instance)
    {
        throw new NotImplementedException();
    }

    public SetResult<Schema>? Set(Schema instance)
    {
        throw new NotImplementedException();
    }

    public void Delete(Schema instance)
    {
        throw new NotImplementedException();
    }

    public IEnumerable<Schema> Export(Schema? filter)
    {
        throw new NotImplementedException();
    }
}
